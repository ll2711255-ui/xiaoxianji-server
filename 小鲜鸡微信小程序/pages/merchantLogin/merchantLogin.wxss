/* 商家登录页 */
.ml-root {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

/* 品牌区 */
.ml-brand {
  text-align: center;
  margin-bottom: 56rpx;
}

.ml-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-full);
  background: var(--color-warning-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.ml-logo-text {
  font-size: 68rpx;
}

.ml-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-1);
  display: block;
}

.ml-desc {
  font-size: var(--font-base);
  color: var(--color-text-3);
  margin-top: 8rpx;
  display: block;
}

/* 登录卡片 */
.ml-card {
  width: 630rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.ml-field {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid var(--color-border);
  padding: 24rpx 0;
  margin-bottom: 8rpx;
}

.ml-label {
  font-size: var(--font-base);
  color: var(--color-text-2);
  width: 120rpx;
  flex-shrink: 0;
}

.ml-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text-1);
}

.ml-submit {
  width: 100%;
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  border-radius: var(--radius-full);
  font-size: var(--font-lg);
  font-weight: 600;
  padding: 22rpx 0;
  margin-top: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

.ml-submit[disabled] {
  background: #CCC;
}

/* 底部 */
.ml-footer {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  margin-top: 40rpx;
}
