/* 商家登录页 */
.ml-root {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

/* 品牌区 */
.ml-brand {
  text-align: center;
  margin-bottom: 56rpx;
}

.ml-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #FFF3E0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.ml-logo-text {
  font-size: 68rpx;
}

.ml-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
}

.ml-desc {
  font-size: 30rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 登录卡片 */
.ml-card {
  width: 630rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 36rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.ml-field {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #E8E8E8;
  padding: 24rpx 0;
  margin-bottom: 8rpx;
}

.ml-label {
  font-size: 32rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.ml-input {
  flex: 1;
  font-size: 32rpx;
  color: #1A1A1A;
}

.ml-submit {
  width: 100%;
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  border-radius: 40rpx;
  font-size: 34rpx;
  font-weight: 600;
  padding: 22rpx 0;
  margin-top: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

.ml-submit[disabled] {
  background: #CCC;
}

/* 底部 */
.ml-footer {
  font-size: 26rpx;
  color: #B0B0B0;
  margin-top: 40rpx;
}
