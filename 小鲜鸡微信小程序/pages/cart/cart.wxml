<view class="page-cart" wx:if="{{!isEmpty}}">
  <!-- 配送信息条 -->
  <view class="cart-delivery-bar">
    <view class="delivery-icon">📍</view>
    <text class="delivery-text">配送约30-60分钟 · 支持到店自提</text>
  </view>

  <!-- 商品列表 -->
  <view class="cart-items">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="cartKey">
      <!-- 勾选框 -->
      <checkbox class="cart-check" checked="{{item.checked}}" data-index="{{index}}" bindchange="onCheckItem" color="#D4420A" />
      <image class="cart-img" src="{{item.image}}" mode="aspectFill" />
      <view class="cart-info">
        <text class="cart-name">{{item.productName}}</text>
        <view class="cart-specs">
          <text class="tag tag-gray" wx:if="{{item.spec.type}}">{{item.spec.type}}</text>
          <text class="tag tag-gray">{{item.spec.weight}}</text>
          <text class="tag tag-gray">{{item.spec.processing}}</text>
        </view>
        <!-- 整鸡预估提示 -->
        <text class="cart-tip" wx:if="{{item.pricingType === 'range_weight'}}">整鸡为预估价，实际以称重为准，差价原路退回</text>
        <view class="cart-row">
          <text class="cart-price-text">¥{{item.priceDisplay}}</text>
          <view class="qty-ctrl">
            <view class="qty-circle" data-index="{{index}}" data-delta="-1" bindtap="onQuantityChange">−</view>
            <text class="qty-num">{{item.quantity}}</text>
            <view class="qty-circle qty-plus" data-index="{{index}}" data-delta="1" bindtap="onQuantityChange">+</view>
          </view>
        </view>
      </view>
      <view class="cart-del" data-index="{{index}}" bindtap="onDeleteItem">
        <text>删除</text>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="cart-bar">
    <view class="cart-bar-left">
      <checkbox checked="{{allChecked}}" bindchange="onCheckAll" color="#D4420A" />
      <text class="all-check-label">全选</text>
    </view>
    <view class="cart-bar-right">
      <view class="cart-total">
        <text class="total-label">合计</text>
        <text class="total-price">¥{{checkedTotalDisplay}}</text>
      </view>
      <view class="cart-checkout {{checkedCount === 0 ? 'cart-checkout-disabled' : ''}}" bindtap="onCheckout">
        <text>去结算({{checkedCount}}件)</text>
      </view>
    </view>
  </view>
</view>

<view class="empty-state" wx:if="{{isEmpty}}">
  <text class="empty-icon">🛒</text>
  <text>购物车是空的</text>
  <text class="empty-hint">去首页逛逛吧</text>
</view>

<!-- Custom TabBar -->
<custom-tab-bar current="cart" theme="customer" bind:change="onTabChange" />
