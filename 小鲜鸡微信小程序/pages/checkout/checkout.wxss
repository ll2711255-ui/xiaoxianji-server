/* ========== 确认订单页面 ========== */
.page-checkout {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 160rpx;
}

/* ========== Tab 切换 ========== */
.tab-bar {
  display: flex;
  background: var(--color-bg-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: var(--font-lg);
  color: var(--color-text-3);
  position: relative;
}

.tab-active {
  color: var(--color-primary);
  font-weight: 700;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: var(--radius-sm);
}

/* ========== 地址卡片 ========== */
.addr-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  margin: 16rpx 24rpx;
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.addr-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-pale);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  flex-shrink: 0;
}

.addr-body {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.addr-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.addr-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-1);
}

.addr-phone {
  font-size: var(--font-base);
  color: var(--color-text-3);
}

.addr-full {
  font-size: var(--font-base);
  color: var(--color-text-3);
  margin-top: 6rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.addr-empty {
  font-size: var(--font-base);
  color: var(--color-primary);
}

.addr-arrow {
  font-size: var(--font-xl);
  color: var(--color-text-3);
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ========== 自取门店卡片 ========== */
.pickup-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  margin: 16rpx 24rpx;
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.pickup-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-pale);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  flex-shrink: 0;
}

.pickup-body {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.pickup-label {
  font-size: var(--font-md);
  color: var(--color-text-3);
  display: block;
}

.pickup-addr {
  font-size: var(--font-base);
  color: var(--color-text-1);
  font-weight: 500;
  margin-top: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pickup-map-icon {
  font-size: var(--font-xl);
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ========== 门店地图 ========== */
.store-map-wrap {
  position: relative;
  margin: 0 24rpx 16rpx;
  height: 280rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}
.store-map {
  width: 100%;
  height: 100%;
}
.store-map-hint {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: var(--font-sm);
  padding: 8rpx 16rpx;
  border-radius: var(--radius-lg);
  pointer-events: none;
}

/* ========== 时间选择 ========== */
.time-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  margin: 0 24rpx 16rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.time-label {
  font-size: var(--font-base);
  color: var(--color-text-1);
  font-weight: 500;
}

.time-capsules {
  display: flex;
  gap: 16rpx;
}

.time-capsule {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
  background: var(--color-bg-page);
  color: var(--color-text-3);
}

.capsule-active {
  background: var(--color-primary-pale);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

/* ========== 预约时间选择器 ========== */
.schedule-card {
  background: var(--color-bg-card);
  margin: 0 24rpx 16rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.schedule-label {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-1);
  display: block;
  margin-bottom: 16rpx;
}

.schedule-label-time {
  margin-top: 24rpx;
}

/* 日期横向滚动 */
.date-scroll {
  white-space: nowrap;
}

.date-scroll-inner {
  display: flex;
  gap: 16rpx;
}

.date-capsule {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
  background: var(--color-bg-page);
  color: var(--color-text-2);
  flex-shrink: 0;
  white-space: nowrap;
}

.date-capsule-active {
  background: var(--color-primary);
  color: #fff;
}

/* 时段网格 */
.time-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-slot {
  width: calc(50% - 8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: var(--radius-md);
  font-size: var(--font-base);
  background: var(--color-bg-page);
  color: var(--color-text-2);
  box-sizing: border-box;
}

.time-slot-active {
  background: var(--color-primary-pale);
  color: var(--color-primary);
  border: 1rpx solid var(--color-primary);
}

/* ========== 商品明细卡片 ========== */
.product-card {
  background: var(--color-bg-card);
  margin: 0 24rpx 16rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-1);
  display: block;
  margin-bottom: 16rpx;
}

.product-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.product-item + .product-item {
  border-top: 1rpx solid var(--color-border);
}

.product-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  margin-left: 16rpx;
  overflow: hidden;
}

.product-name {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--color-text-1);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-specs {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.product-price-col {
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.product-qty-price {
  font-size: var(--font-md);
  color: var(--color-text-3);
  display: block;
}

.product-subtotal {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
  display: block;
}

.card-divider {
  height: 1rpx;
  background: var(--color-bg-page);
  margin: 16rpx 0;
}

.product-total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-label {
  font-size: var(--font-base);
  color: var(--color-text-1);
}

.total-amount {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
}

.range-note {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  display: block;
  margin-top: 12rpx;
  line-height: 1.5;
}

.range-note-warn {
  color: var(--color-warning);
}

/* ========== 支付金额卡片 ========== */
.payment-card {
  background: var(--color-bg-card);
  margin: 0 24rpx 16rpx;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.payment-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
}

.payment-label {
  font-size: var(--font-base);
  color: var(--color-text-3);
}

.payment-val {
  font-size: var(--font-base);
  color: var(--color-text-1);
}

.payment-total-row {
  padding-top: 4rpx;
}

.payment-total-row .payment-label {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-1);
}

.payment-total {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

/* ========== 提交栏 ========== */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  border-radius: var(--radius-full);
  padding: 24rpx;
  font-size: var(--font-lg);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

.submit-btn:active {
  opacity: 0.85;
}

.submit-price {
  font-size: var(--font-lg);
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

/* ========== 手机号授权浮层 ========== */
.phone-auth-overlay {
  position: fixed;
  z-index: 200;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-auth-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.phone-auth-card {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.phone-auth-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-1);
  margin-bottom: 12rpx;
}

.phone-auth-desc {
  font-size: var(--font-base);
  color: var(--color-text-3);
  margin-bottom: 36rpx;
  line-height: 1.5;
}

.phone-auth-btn {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-full);
  font-size: var(--font-lg);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.phone-auth-btn::after {
  border: none;
}

.phone-auth-btn:active {
  opacity: 0.9;
}

.phone-auth-cancel {
  margin-top: 24rpx;
  padding: 16rpx 32rpx;
}

.phone-auth-cancel text {
  font-size: var(--font-base);
  color: var(--color-text-3);
}

/* ========== 配送范围超限弹窗 ========== */
.range-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1010;
  display: flex;
  align-items: center;
  justify-content: center;
}
.range-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}
.range-card {
  position: relative;
  width: 600rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.range-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.range-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-danger);
  margin-bottom: 16rpx;
}
.range-msg {
  font-size: var(--font-base);
  color: var(--color-text-1);
  line-height: 1.5;
  margin-bottom: 8rpx;
}
.range-detail {
  font-size: var(--font-md);
  color: var(--color-text-3);
  margin-bottom: 16rpx;
}
.range-suggest {
  font-size: var(--font-base);
  color: var(--color-primary);
  font-weight: 600;
  margin-bottom: 32rpx;
}
.range-btns {
  display: flex;
  width: 100%;
  gap: 20rpx;
}
.range-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: 600;
  border: none;
  padding: 0;
}
.range-btn::after {
  display: none;
}
.range-btn-cancel {
  background: var(--color-bg-page);
  color: var(--color-text-2);
}
.range-btn-pickup {
  background: var(--color-primary);
  color: #fff;
}
