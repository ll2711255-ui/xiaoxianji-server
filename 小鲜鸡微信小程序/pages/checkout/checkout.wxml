<view class="page-checkout">
  <!-- ========== Tab 切换 ========== -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === 'delivery' ? 'tab-active' : ''}}"
      wx:if="{{showDeliveryTab}}"
      bindtap="onTabTap"
      data-tab="delivery"
    >
      <text>外卖配送</text>
    </view>
    <view
      class="tab-item {{currentTab === 'pickup' ? 'tab-active' : ''}}"
      wx:if="{{showPickupTab}}"
      bindtap="onTabTap"
      data-tab="pickup"
    >
      <text>到店自取</text>
    </view>
  </view>

  <!-- ========== 配送 — 收货地址卡片 ========== -->
  <view class="addr-card" wx:if="{{currentTab === 'delivery'}}" bindtap="onSelectAddress">
    <view class="addr-icon">
      <text>📍</text>
    </view>
    <block wx:if="{{address}}">
      <view class="addr-body">
        <view class="addr-top">
          <text class="addr-name">{{address.name}}</text>
          <text class="addr-phone">{{address.phone}}</text>
        </view>
        <text class="addr-full">{{address.province}}{{address.city}}{{address.district}} {{address.detail}}</text>
      </view>
    </block>
    <block wx:else>
      <view class="addr-body">
        <text class="addr-empty">+ 新增收货地址</text>
      </view>
    </block>
    <text class="addr-arrow">›</text>
  </view>

  <!-- ========== 自取 — 门店信息卡片 ========== -->
  <view class="pickup-card" wx:if="{{currentTab === 'pickup'}}">
    <view class="pickup-icon">
      <text>🏪</text>
    </view>
    <view class="pickup-body">
      <text class="pickup-label">自取门店</text>
      <text class="pickup-addr">{{storeAddress}}</text>
    </view>
    <view class="pickup-map-icon">
      <text>📍</text>
    </view>
  </view>

  <!-- ========== 自取 — 门店地图 ========== -->
  <view class="store-map-wrap" wx:if="{{currentTab === 'pickup'}}" bindtap="onNavigateToStore">
    <map
      id="storeMap"
      class="store-map"
      latitude="{{storeLat}}"
      longitude="{{storeLng}}"
      markers="{{storeMarker}}"
      scale="{{15}}"
      show-location
    />
    <view class="store-map-hint">
      <text>📍 点击地图导航到店</text>
    </view>
  </view>

  <!-- ========== 时间选择 ========== -->
  <view class="time-card">
    <text class="time-label">{{currentTab === 'delivery' ? '配送时间' : '自取时间'}}</text>
    <view class="time-capsules">
      <view
        class="time-capsule {{!isScheduled ? 'capsule-active' : ''}}"
        bindtap="onTimeCapsuleTap"
        data-type="now"
      >
        <text>{{currentTab === 'delivery' ? '立即配送' : '立即自取'}}</text>
      </view>
      <view
        class="time-capsule {{isScheduled ? 'capsule-active' : ''}}"
        bindtap="onTimeCapsuleTap"
        data-type="scheduled"
      >
        <text>{{scheduleDate && scheduleTime ? scheduleDate + ' ' + scheduleTime : '预约时间'}}</text>
      </view>
    </view>
  </view>

  <!-- ========== 预约时间选择器 ========== -->
  <view class="schedule-card" wx:if="{{isScheduled}}">
    <!-- 选择日期 -->
    <text class="schedule-label">选择日期</text>
    <scroll-view class="date-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="date-scroll-inner">
        <view
          wx:for="{{dateOptions}}"
          wx:key="value"
          class="date-capsule {{scheduleDate === item.value ? 'date-capsule-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onDateSelect"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 选择时间段 -->
    <text class="schedule-label schedule-label-time">选择时间段</text>
    <view class="time-grid">
      <view
        wx:for="{{timeOptions}}"
        wx:key="value"
        class="time-slot {{scheduleTime === item.value ? 'time-slot-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onTimeSelect"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- ========== 商品明细卡片 ========== -->
  <view class="product-card">
    <text class="card-title">商品明细</text>
    <view class="product-item" wx:for="{{items}}" wx:key="cartKey">
      <view class="product-thumb">
        <text>{{item.emoji}}</text>
      </view>
      <view class="product-info">
        <text class="product-name">{{item.productName}}</text>
        <view class="product-specs">
          <text class="tag tag-gray" wx:if="{{item.spec.type}}">{{item.spec.type}}</text>
          <text class="tag tag-gray">{{item.spec.weight}}</text>
          <text class="tag tag-gray" wx:if="{{item.spec.processing}}">{{item.spec.processing}}</text>
        </view>
      </view>
      <view class="product-price-col">
        <text class="product-qty-price">×{{item.quantity}}</text>
        <text class="product-subtotal">¥{{item.subtotalDisplay}}</text>
        <text class="tag tag-orange" wx:if="{{item.pricingType === 'range_weight'}}">预估价</text>
      </view>
    </view>
    <view class="card-divider"></view>
    <view class="product-total-row">
      <text class="total-label">商品合计</text>
      <text class="total-amount">¥{{totalDisplay}}</text>
    </view>
    <text class="range-note" wx:if="{{hasRangeWeight}}">*整鸡按实际称重结算，差价原路退回</text>
  </view>

  <!-- ========== 支付金额卡片 ========== -->
  <view class="payment-card">
    <view class="payment-row">
      <text class="payment-label">商品金额</text>
      <text class="payment-val">¥{{totalDisplay}}</text>
    </view>
    <view class="payment-row">
      <text class="payment-label">配送费</text>
      <text class="payment-val">¥{{deliveryFeeDisplay}}</text>
    </view>
    <view class="card-divider"></view>
    <view class="payment-row payment-total-row">
      <text class="payment-label">实付金额</text>
      <text class="payment-total">¥{{finalTotalDisplay}}</text>
    </view>
    <text class="range-note range-note-warn" wx:if="{{hasRangeWeight}}">预收金额，非最终金额</text>
  </view>

  <!-- 底部留白 -->
  <view style="height: 160rpx;"></view>

  <!-- ========== 手机号授权浮层 ========== -->
  <view class="phone-auth-overlay" wx:if="{{showPhoneAuth}}">
    <view class="phone-auth-mask" catchtap="onCancelPhoneAuth"></view>
    <view class="phone-auth-card">
      <text class="phone-auth-title">绑定手机号</text>
      <text class="phone-auth-desc">下单前需要绑定手机号，方便商家联系您</text>
      <button class="phone-auth-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneForOrder">
        微信手机号一键授权
      </button>
      <view class="phone-auth-cancel" bindtap="onCancelPhoneAuth">
        <text>暂不绑定</text>
      </view>
    </view>
  </view>

  <!-- ========== 配送范围超限弹窗 ========== -->
  <view class="range-overlay" wx:if="{{showRangeModal}}">
    <view class="range-mask" catchtap="onCloseRangeModal"></view>
    <view class="range-card">
      <view class="range-icon">📍</view>
      <text class="range-title">超出配送范围</text>
      <text class="range-msg">{{rangeModalMsg}}</text>
      <text class="range-detail">当前距离店铺约 {{rangeModalDistance}} 公里，配送半径 {{rangeModalRadius}} 公里</text>
      <text class="range-suggest">请选择到店自取</text>
      <view class="range-btns">
        <button class="range-btn range-btn-cancel" bindtap="onCloseRangeModal">留在配送</button>
        <button class="range-btn range-btn-pickup" bindtap="onSwitchToPickup">到店自取</button>
      </view>
    </view>
  </view>

  <!-- ========== 提交栏 ========== -->
  <view class="submit-bar">
    <view class="submit-btn" bindtap="onSubmit">
      <text>提交订单</text>
      <text class="submit-price">¥{{finalTotalDisplay}}</text>
    </view>
  </view>
</view>
