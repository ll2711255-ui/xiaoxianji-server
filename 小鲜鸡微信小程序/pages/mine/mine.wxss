/* ================================================================
   我的页面 — pages/mine/mine
   设计规范：
   - 页背景 #F5F5F5，卡片间距 16rpx
   - 顶部用户区背景 #1DB96A，文字白色
   - 列表项左侧彩色圆形图标，右侧灰色箭头 ›
   ================================================================ */

/* ---- 页面 ---- */
page {
  background: #F5F5F5;
}

.page-mine {
  min-height: 100vh;
  background: #F5F5F5;
}

/* ====================================================================
   1. 用户信息区 — 绿色背景 + 白色文字
   ==================================================================== */

.m-header {
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
  padding: 60rpx 32rpx 56rpx;
}

.m-header-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

/* 未登录态整行点击区 */
.m-header-tap {
  display: flex;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

/* ---- 头像按钮 ---- */
.m-avatar-btn {
  width: 120rpx;
  min-width: 120rpx;
  max-width: 120rpx;
  height: 120rpx;
  min-height: 120rpx;
  max-height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.2);
  padding: 0;
  margin: 0;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.m-avatar-btn::after {
  display: none;
}

.m-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.m-avatar-placeholder {
  font-size: 60rpx;
  display: block;
  line-height: 120rpx;
  text-align: center;
  width: 100%;
}

/* 未登录态默认头像（view 容器，居中 emoji） */
.m-avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.2);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 未登录态副标题 */
.m-login-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
  display: block;
}

/* ---- 右侧用户信息 ---- */
.m-user-info {
  flex: 1;
  min-width: 0;
}

.m-nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  background: transparent;
  border: none;
  padding: 0;
  width: 100%;
  height: 48rpx;
  line-height: 48rpx;
  box-sizing: border-box;
}

.m-nickname--dim {
  opacity: 0.7;
  font-weight: 400;
}

/* 未登录点击区域 — 确保可点 */
.m-login-tap {
  width: 100%;
  min-height: 60rpx;
  display: flex;
  align-items: center;
}

.m-phone {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
  display: block;
}

/* 绑定手机号按钮 */
.m-phone-btn {
  display: inline-block;
  margin-top: 10rpx;
  padding: 10rpx 28rpx;
  font-size: 28rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 32rpx;
  line-height: 1.3;
}

.m-phone-btn::after {
  display: none;
}

/* ====================================================================
   2. 订单快捷入口 — 白色卡片
   ==================================================================== */

.m-card {
  margin: 16rpx 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.m-order-card {
  margin-top: -24rpx;
  position: relative;
  z-index: 1;
}

.m-order-grid {
  display: flex;
  padding: 28rpx 0;
}

.m-order-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  position: relative;
}

.m-order-item:active {
  opacity: 0.7;
}

/* 彩色图标底 */
.m-order-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.m-order-icon-wrap text {
  font-size: 40rpx;
}

.m-order-icon--yellow {
  background: #FFF8E1;
}
.m-order-icon--orange {
  background: #FFF0E6;
}
.m-order-icon--green {
  background: #E8F8F0;
}
.m-order-icon--blue {
  background: var(--color-brand-orange-bg);
}

.m-order-label {
  font-size: 28rpx;
  color: #333;
}

/* 红色角标 */
.m-order-badge {
  position: absolute;
  top: -4rpx;
  right: 50%;
  transform: translateX(44rpx);
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 16rpx;
  text-align: center;
  box-sizing: border-box;
}

/* ====================================================================
   3. 功能列表 & 4. 其他列表 — 箭头列表样式
   ==================================================================== */

.m-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
}

.m-list-item:active {
  background: #FAFAFA;
}

.m-list-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.m-list-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.m-list-icon text {
  font-size: 30rpx;
}

/* 图标底色 */
.m-list-icon--red    { background: var(--color-brand-red-bg); }
.m-list-icon--teal   { background: var(--color-brand-gold-bg); }
.m-list-icon--purple { background: var(--color-brand-red-bg); }
.m-list-icon--blue   { background: var(--color-brand-cream-bg); }
.m-list-icon--gray   { background: #F5F5F5; }

.m-list-text {
  font-size: 34rpx;
  color: #1A1A1A;
}

.m-list-right {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.m-list-extra {
  font-size: 30rpx;
  color: #B0B0B0;
}

.m-list-arrow {
  font-size: 40rpx;
  color: #C7C7CC;
  line-height: 1;
}

/* 开关 */
.m-list-switch {
  transform: scale(0.85);
  margin-right: -4rpx;
}

/* 分割线 */
.m-list-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin-left: 100rpx;
}

/* ====================================================================
   其他卡片间距
   ==================================================================== */

.m-feature-card {
  margin-top: 16rpx;
}

.m-merchant-card {
  margin-top: 16rpx;
}

.m-other-card {
  margin-top: 16rpx;
}

/* ====================================================================
   5. 登录横幅
   ==================================================================== */

.login-banner {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 16rpx 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  border: 1rpx solid #eee;
}

.login-banner:active {
  background: #FAFAFA;
}

.banner-icon {
  font-size: 40rpx;
}

.banner-text {
  flex: 1;
  font-size: 30rpx;
  color: #555;
  margin-left: 12rpx;
}

.banner-btn {
  background: #F0FAF5;
  color: #1DB96A;
  border: 1rpx solid #1DB96A;
  border-radius: 32rpx;
  padding: 10rpx 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* ====================================================================
   6. 底部登录弹窗
   ==================================================================== */

/* 遮罩 — z-index 需高于 custom-tab-bar（1000） */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1001;
  display: flex;
  align-items: flex-end;
}

/* 底部弹窗主体 */
.login-sheet {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 48rpx 80rpx;
  position: relative;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

/* 关闭按钮 */
.sheet-close {
  position: absolute;
  top: 28rpx;
  right: 36rpx;
  font-size: 48rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 标题 */
.sheet-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.sheet-subtitle {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 48rpx;
  line-height: 1.6;
}

/* 协议行 */
.agreement-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #CCC;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #1DB96A;
  border-color: #1DB96A;
}

.check-icon {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.agreement-text {
  font-size: 28rpx;
  color: #999;
}

.agreement-link {
  font-size: 28rpx;
  color: #1DB96A;
}

/* 协议提示 */
.agreement-tip {
  font-size: 26rpx;
  color: #FF4B26;
  margin-bottom: 16rpx;
  padding-left: 48rpx;
}

/* 手机号一键登录按钮 */
.phone-login-btn {
  width: 100%;
  background: #1DB96A;
  color: #fff;
  border-radius: 88rpx;
  font-size: 36rpx;
  font-weight: 600;
  margin-top: 32rpx;
  margin-bottom: 0;
  border: none;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
}

.phone-login-btn::after {
  display: none;
}

.phone-login-btn.btn-disabled {
  background: #A8DFC4;
}

/* 暂不登录 */
.skip-login {
  text-align: center;
  font-size: 30rpx;
  color: #999;
  margin-top: 48rpx;
  padding: 16rpx;
}
