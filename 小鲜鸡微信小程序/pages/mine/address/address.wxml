<view class="address-page">
  <!-- 地址列表 -->
  <view class="address-list">
    <view
      class="address-card {{selectMode ? '' : 'address-card--tappable'}}"
      wx:for="{{addresses}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="{{selectMode ? 'onSelectAddress' : ''}}"
      bindlongpress="onAddressLongPress"
    >
      <!-- 左侧：地址信息 -->
      <view class="addr-body">
        <view class="addr-header">
          <text class="addr-name">{{item.name}}</text>
          <text class="addr-phone">{{item.phone}}</text>
          <text class="tag tag-green" wx:if="{{item.isDefault}}">默认</text>
        </view>
        <text class="addr-detail">{{item.province}}{{item.city}}{{item.district}} {{item.detail}}</text>
      </view>

      <!-- 右侧：操作按钮（非选择模式） -->
      <view class="addr-actions" wx:if="{{!selectMode}}">
        <view class="addr-action-btn" data-id="{{item._id}}" catchtap="onEditAddress">
          <text>编辑</text>
        </view>
        <view class="addr-action-btn addr-action-del" wx:if="{{!item.isDefault}}" data-id="{{item._id}}" catchtap="onDeleteAddress">
          <text>删除</text>
        </view>
      </view>

      <!-- 右侧：选中图标（选择模式） -->
      <view class="addr-select-icon" wx:if="{{selectMode}}">
        <text>›</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{addresses.length === 0}}">
      <text class="empty-icon">📍</text>
      <text>暂无收货地址</text>
      <text class="empty-hint">点击下方按钮添加收货地址</text>
    </view>
  </view>

  <!-- 底部添加按钮 -->
  <view class="add-btn-wrap">
    <view class="add-btn" bindtap="onManualAdd">
      <text class="add-btn-icon">✏️</text>
      <text>添加收货地址</text>
    </view>
  </view>
</view>
