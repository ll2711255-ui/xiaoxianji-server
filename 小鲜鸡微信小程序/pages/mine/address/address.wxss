/* ========== 地址管理页 ========== */
.address-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.address-list {
  padding: 16rpx 24rpx;
  padding-bottom: 200rpx;
}

/* ========== 地址卡片 ========== */
.address-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.address-card--tappable:active {
  background: var(--color-bg-page);
}

.addr-body {
  flex: 1;
  overflow: hidden;
}

.addr-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.addr-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-1);
}

.addr-phone {
  font-size: var(--font-base);
  color: var(--color-text-3);
}

.addr-detail {
  font-size: var(--font-base);
  color: var(--color-text-3);
  display: block;
  line-height: 1.5;
}

/* ========== 右侧操作按钮 ========== */
.addr-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.addr-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 48rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-page);
}

.addr-action-btn text {
  font-size: var(--font-sm);
  color: var(--color-text-2);
}

.addr-action-del {
  background: var(--color-primary-pale);
}

.addr-action-del text {
  color: var(--color-danger);
}

.addr-select-icon {
  font-size: 44rpx;
  color: var(--color-text-3);
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ========== 底部添加按钮 ========== */
.add-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  border-radius: var(--radius-full);
  padding: 24rpx 0;
  font-size: var(--font-base);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

.add-btn:active {
  opacity: 0.85;
}

.add-btn-icon {
  font-size: var(--font-base);
}
