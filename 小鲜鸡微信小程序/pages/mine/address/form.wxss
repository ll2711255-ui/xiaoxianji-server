/* ========== 地址表单页 ========== */
.form-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-top: 16rpx;
}

/* ========== 表单卡片 ========== */
.form-card {
  background: var(--color-bg-card);
  margin: 0 24rpx 16rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.form-row {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.form-row-last {
  border-bottom: none;
}

.form-label {
  width: 140rpx;
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--color-text-1);
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text-1);
  text-align: right;
}

.form-input::placeholder {
  color: var(--color-text-3);
}

.form-picker-val {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.form-picker-val text {
  font-size: var(--font-base);
  color: var(--color-text-1);
}

.form-placeholder {
  color: var(--color-text-3) !important;
}

.form-arrow {
  font-size: var(--font-lg);
  color: var(--color-text-3);
}

.form-row-switch {
  justify-content: space-between;
}

/* ========== 按钮 ========== */
.form-btn-wrap {
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.form-save-btn {
  width: 100%;
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  border-radius: var(--radius-full);
  font-size: var(--font-lg);
  font-weight: 600;
  padding: 24rpx 0;
  border: none;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

.form-save-btn:active {
  opacity: 0.85;
}

.form-save-btn[disabled] {
  background: #C7C7CC;
}

.form-delete-btn {
  text-align: center;
  margin-top: 28rpx;
}

.form-delete-btn text {
  font-size: var(--font-base);
  color: var(--color-danger);
}
