<view class="form-page">
  <!-- 表单区域 -->
  <view class="form-card">
    <!-- 收货人 -->
    <view class="form-row">
      <text class="form-label">收货人</text>
      <input
        class="form-input"
        placeholder="请输入收货人姓名"
        value="{{name}}"
        bindinput="onInput"
        data-field="name"
        maxlength="20"
      />
    </view>

    <!-- 手机号 -->
    <view class="form-row">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        type="number"
        placeholder="请输入手机号码"
        value="{{phone}}"
        bindinput="onInput"
        data-field="phone"
        maxlength="11"
      />
    </view>

    <!-- 所在地区 -->
    <view class="form-row">
      <text class="form-label">所在地区</text>
      <picker
        mode="region"
        value="{{region}}"
        bindchange="onRegionChange"
      >
        <view class="form-picker-val">
          <text class="{{region[0] ? '' : 'form-placeholder'}}">{{region[0] ? region[0] + ' ' + region[1] + ' ' + region[2] : '请选择省市区'}}</text>
          <text class="form-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 详细地址 -->
    <view class="form-row form-row-last">
      <text class="form-label">门牌号</text>
      <input
        class="form-input"
        placeholder="街道、楼栋、门牌号等"
        value="{{detail}}"
        bindinput="onInput"
        data-field="detail"
        maxlength="100"
      />
    </view>
  </view>

  <!-- 默认地址 -->
  <view class="form-card">
    <view class="form-row form-row-last form-row-switch">
      <text class="form-label">设为默认地址</text>
      <switch
        checked="{{isDefault}}"
        bindchange="onSwitchChange"
        color="#D4420A"
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="form-btn-wrap">
    <button class="form-save-btn" bindtap="onSave" loading="{{saving}}" disabled="{{saving}}">
      保存地址
    </button>

    <view class="form-delete-btn" wx:if="{{isEdit}}" bindtap="onDelete">
      <text>删除地址</text>
    </view>
  </view>
</view>
