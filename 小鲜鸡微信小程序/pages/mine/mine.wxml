<!-- 我的页面 -->
<view class="page-mine">

  <!-- ============================================================ -->
  <!-- 1. 用户信息区 — 金黄渐变背景 + 白色内容 -->
  <!-- ============================================================ -->
  <view class="m-header">
    <view class="m-header-card">
      <!-- 未登录：整行可点 → 弹出登录弹窗 -->
      <view wx:if="{{!isLoggedIn}}" class="m-header-tap" bindtap="onShowLoginModal">
        <view class="m-avatar-default">
          <text class="m-avatar-placeholder">🐔</text>
        </view>
        <view class="m-user-info">
          <text class="m-nickname">亲爱的用户</text>
          <text class="m-login-sub">登录后享受更多服务</text>
        </view>
      </view>
      <!-- 已登录：可换头像 + 昵称 + 脱敏手机号 -->
      <block wx:else>
        <button class="m-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="m-avatar-img" src="{{avatarUrl}}" mode="aspectFill" wx:if="{{avatarUrl}}" />
          <text class="m-avatar-placeholder" wx:else>🐔</text>
        </button>
        <view class="m-user-info">
          <input class="m-nickname" type="nickname" value="{{nickName}}" placeholder="点击设置昵称" placeholder-style="color:rgba(255,255,255,0.45);font-size:28rpx;" bindblur="onNicknameBlur" maxlength="12" />
          <text class="m-phone" wx:if="{{maskedPhone}}">{{maskedPhone}}</text>
          <button class="m-phone-btn" wx:else open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">绑定手机号</button>
        </view>
      </block>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- 1.5 登录横幅 — 未登录时显示 -->
  <!-- ============================================================ -->
  <view wx:if="{{!isLoggedIn}}" class="login-banner" bindtap="onShowLoginModal">
    <text class="banner-icon">💎</text>
    <text class="banner-text">登录账号，享受完整服务</text>
    <view class="banner-btn">登录/注册</view>
  </view>

  <!-- ============================================================ -->
  <!-- 2. 订单快捷入口 — 白色卡片 · 一行四格 -->
  <!-- ============================================================ -->
  <view class="m-card m-order-card">
    <view class="m-order-grid">
      <view class="m-order-item" bindtap="onOrderTap" data-tab="pending">
        <view class="m-order-icon-wrap m-order-icon--yellow">
          <text>📋</text>
        </view>
        <text class="m-order-label">待付款</text>
      </view>
      <view class="m-order-item" bindtap="onOrderTap" data-tab="active">
        <view class="m-order-icon-wrap m-order-icon--orange">
          <text>🔄</text>
        </view>
        <text class="m-order-label">进行中</text>
        <view class="m-order-badge" wx:if="{{ongoingCount > 0}}">{{ongoingCount > 99 ? '99+' : ongoingCount}}</view>
      </view>
      <view class="m-order-item" bindtap="onOrderTap" data-tab="completed">
        <view class="m-order-icon-wrap m-order-icon--green">
          <text>✅</text>
        </view>
        <text class="m-order-label">已完成</text>
      </view>
      <view class="m-order-item" bindtap="onOrderTap" data-tab="all">
        <view class="m-order-icon-wrap m-order-icon--blue">
          <text>📦</text>
        </view>
        <text class="m-order-label">全部订单</text>
      </view>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- 3. 功能列表 — 白色卡片 · 箭头列表 -->
  <!-- ============================================================ -->
  <view class="m-card m-feature-card">
    <view class="m-list-item" bindtap="onAddressManage">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--red">
          <text>📍</text>
        </view>
        <text class="m-list-text">收货地址管理</text>
      </view>
      <text class="m-list-arrow">›</text>
    </view>

    <view class="m-list-divider"></view>

    <view class="m-list-item" bindtap="onScanPickup">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--teal">
          <text>📷</text>
        </view>
        <text class="m-list-text">扫码取货</text>
      </view>
      <text class="m-list-arrow">›</text>
    </view>

    <view class="m-list-divider"></view>

    <view class="m-list-item">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--purple">
          <text>🔔</text>
        </view>
        <text class="m-list-text">消息通知</text>
      </view>
      <switch class="m-list-switch" checked="{{notificationEnabled}}" disabled />
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- 3.5 商家端入口 — 始终可见，未登录商家时跳转登录页 -->
  <!-- ============================================================ -->
  <view class="m-card m-merchant-card">
    <view class="m-list-item" bindtap="onMerchantEntry">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--teal">
          <text>🏪</text>
        </view>
        <text class="m-list-text">{{isMerchant ? '商家管理' : '商家登录'}}</text>
      </view>
      <text class="m-list-arrow">›</text>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- 4. 其他列表 — 白色卡片 -->
  <!-- ============================================================ -->
  <view class="m-card m-other-card">
    <view class="m-list-item" bindtap="onContactService">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--blue">
          <text>💬</text>
        </view>
        <text class="m-list-text">联系客服</text>
      </view>
      <text class="m-list-arrow">›</text>
    </view>

    <view class="m-list-divider"></view>

    <view class="m-list-item" bindtap="onAbout">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--gray">
          <text>ℹ️</text>
        </view>
        <text class="m-list-text">关于小鲜鸡</text>
      </view>
      <view class="m-list-right">
        <text class="m-list-extra">v{{appVersion}}</text>
        <text class="m-list-arrow">›</text>
      </view>
    </view>

    <view class="m-list-divider" wx:if="{{isDev}}"></view>

    <view class="m-list-item" wx:if="{{isDev}}" bindtap="onClearMockData">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--red">
          <text>🗑️</text>
        </view>
        <text class="m-list-text">清除模拟数据</text>
      </view>
      <text class="m-list-arrow">›</text>
    </view>

    <view class="m-list-divider" wx:if="{{isDev}}"></view>

    <view class="m-list-item" wx:if="{{isDev}}" bindtap="onClearTestData">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--red">
          <text>⚠️</text>
        </view>
        <text class="m-list-text">清除全部测试数据</text>
      </view>
      <text class="m-list-arrow">›</text>
    </view>

    <view class="m-list-divider" wx:if="{{isLoggedIn}}"></view>

    <view class="m-list-item" wx:if="{{isLoggedIn}}" bindtap="onLogout">
      <view class="m-list-left">
        <view class="m-list-icon m-list-icon--red">
          <text>🚪</text>
        </view>
        <text class="m-list-text">退出登录</text>
      </view>
      <text class="m-list-arrow">›</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view style="height: 120rpx;"></view>

  <!-- ============================================================ -->
  <!-- 5. 底部登录弹窗 — 未登录时点击横幅弹出 -->
  <!-- ============================================================ -->
  <view wx:if="{{showLoginModal}}" class="modal-mask" bindtap="onMaskTap">
    <view class="login-sheet" catchtap="stopPropagation">

      <!-- 关闭按钮 -->
      <view class="sheet-close" bindtap="onCloseModal">×</view>

      <!-- 品牌标题 -->
      <view class="sheet-title">欢迎使用小鲜鸡</view>
      <view class="sheet-subtitle">登录后可下单、查订单、享受配送服务</view>

      <!-- 协议勾选 -->
      <view class="agreement-row">
        <view class="checkbox {{agreedProtocol ? 'checked' : ''}}" bindtap="onToggleAgreement">
          <text wx:if="{{agreedProtocol}}" class="check-icon">✓</text>
        </view>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" bindtap="onViewPrivacy">《隐私政策》</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link" bindtap="onViewService">《服务协议》</text>
      </view>

      <!-- 未勾选协议提示 -->
      <view wx:if="{{showAgreementTip}}" class="agreement-tip">请先阅读并同意相关协议</view>

      <!-- 手机号一键登录按钮 -->
      <button
        class="phone-login-btn {{agreedProtocol ? '' : 'btn-disabled'}}"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
      >手机号一键登录</button>

      <!-- 暂不登录 -->
      <view class="skip-login" bindtap="onCloseModal">暂不登录</view>

    </view>
  </view>

  <!-- Custom TabBar -->
  <custom-tab-bar current="mine" theme="customer" bind:change="onTabChange" />

</view>
