<view class="mpro-page">
  <scroll-view class="mpro-scroll" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- Merchant info card -->
    <view class="mpro-header">
      <view class="mpro-avatar">
        <text>🏪</text>
      </view>
      <view class="mpro-shop-info">
        <text class="mpro-shop-name">{{shopName}}</text>
        <text class="mpro-shop-id">ID: {{merchantId}}</text>
      </view>
      <view class="mpro-role-tag">{{roleLabel}}</view>
    </view>

    <!-- Function menu -->
    <view class="card-full" style="margin-top: 16rpx;">
      <text class="mpro-sec-title">店铺管理</text>

      <view class="mpro-item" bindtap="onShopInfo">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">🏪</text>
          <text>店铺信息</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onNumbers">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">🔢</text>
          <text>号码牌管理</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onOfflineCashier">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">💵</text>
          <text>线下收银</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onDeliverySettings">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">🚚</text>
          <text>配送设置</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onBusinessHours">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">🕐</text>
          <text>营业时间</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onConnectPrinter">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">🖨</text>
          <text>连接打印机</text>
        </view>
        <view class="mpro-item-right">
          <text class="mpro-printer-status" wx:if="{{connectedPrinterName}}">{{connectedPrinterName}}</text>
          <text class="mpro-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- Account section -->
    <view class="card-full">
      <text class="mpro-sec-title">账号管理</text>

      <view class="mpro-item" bindtap="onAccountInfo">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">👤</text>
          <text>账号信息</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onChangePassword">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">🔐</text>
          <text>修改密码</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onHelp">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">❓</text>
          <text>使用帮助</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>

      <view class="mpro-item" bindtap="onAbout">
        <view class="mpro-item-left">
          <text class="mpro-item-icon">ℹ️</text>
          <text>关于</text>
        </view>
        <text class="mpro-arrow">›</text>
      </view>
    </view>

    <!-- Logout -->
    <view class="mpro-logout-wrap">
      <button class="mpro-logout-btn" bindtap="onLogout">退出商家模式</button>
      <text class="mpro-version">小鲜鸡商家端 v1.0.0</text>
    </view>

    <view style="height: 140rpx;"></view>
  </scroll-view>

  <!-- ============================================================ -->
  <!-- 店铺信息弹窗 -->
  <!-- ============================================================ -->
  <view class="mpro-modal-mask" wx:if="{{showShopModal}}" bindtap="onCloseShopModal">
    <view class="mpro-modal-card" catchtap="onPreventClose">
      <view class="mpro-modal-head">
        <text class="mpro-modal-title">店铺信息</text>
        <view class="mpro-modal-close" bindtap="onCloseShopModal">×</view>
      </view>
      <view class="mpro-modal-body">
        <!-- 店铺名称 -->
        <view class="mpro-modal-field-block">
          <text class="mpro-modal-label">店铺名称</text>
          <input
            class="mpro-modal-input-full"
            type="text"
            maxlength="20"
            value="{{shopNameInput}}"
            bindinput="onShopNameInput"
            placeholder="请输入店铺名称"
          />
        </view>

        <!-- 店铺地址 -->
        <view class="mpro-modal-field-block">
          <text class="mpro-modal-label">店铺地址</text>
          <view class="mpro-addr-row">
            <text class="mpro-addr-text {{shopAddressInput ? '' : 'mpro-addr-placeholder'}}">{{shopAddressInput || '请在地图上选择店铺位置'}}</text>
            <text class="mpro-addr-pin" bindtap="onChooseLocation">📍 选点</text>
          </view>
          <text class="mpro-modal-hint">点击「选点」在地图上设置店铺准确坐标，用于计算配送距离</text>

          <!-- 地图预览：显示已选位置 -->
          <view class="mpro-map-wrap" wx:if="{{shopLat && shopLng}}">
            <map
              id="shopMap"
              class="mpro-map"
              latitude="{{shopLat}}"
              longitude="{{shopLng}}"
              markers="{{shopMarker}}"
              scale="{{15}}"
              show-location
            />
          </view>
        </view>
      </view>
      <view class="mpro-modal-foot">
        <button class="mpro-modal-cancel" bindtap="onCloseShopModal">取消</button>
        <button class="mpro-modal-save" bindtap="onSaveShopInfo" loading="{{savingShop}}">保存</button>
      </view>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- 账号信息弹窗 -->
  <!-- ============================================================ -->
  <view class="mpro-modal-mask" wx:if="{{showAccountModal}}" bindtap="onCloseAccountModal">
    <view class="mpro-modal-card" catchtap="onPreventClose">
      <view class="mpro-modal-head">
        <text class="mpro-modal-title">账号信息</text>
        <view class="mpro-modal-close" bindtap="onCloseAccountModal">×</view>
      </view>
      <view class="mpro-modal-body">
        <text class="mpro-modal-desc">填写联系人信息，客户下单后将看到您的联系方式。</text>

        <!-- 联系人姓名 -->
        <view class="mpro-modal-field-block">
          <text class="mpro-modal-label">联系人</text>
          <input
            class="mpro-modal-input-full"
            type="text"
            maxlength="15"
            value="{{accountNameInput}}"
            bindinput="onAccountNameInput"
            placeholder="请输入姓名"
          />
        </view>

        <!-- 联系电话 -->
        <view class="mpro-modal-field-block">
          <text class="mpro-modal-label">联系电话</text>
          <input
            class="mpro-modal-input-full"
            type="number"
            maxlength="11"
            value="{{accountPhoneInput}}"
            bindinput="onAccountPhoneInput"
            placeholder="请输入手机号"
          />
        </view>
      </view>
      <view class="mpro-modal-foot">
        <button class="mpro-modal-cancel" bindtap="onCloseAccountModal">取消</button>
        <button class="mpro-modal-save" bindtap="onSaveAccountInfo" loading="{{savingAccount}}">保存</button>
      </view>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- 配送设置弹窗 -->
  <!-- ============================================================ -->
  <view class="mpro-modal-mask" wx:if="{{showDeliveryModal}}" bindtap="onCloseDeliveryModal">
    <view class="mpro-modal-card" catchtap="onPreventClose">
      <view class="mpro-modal-head">
        <text class="mpro-modal-title">配送范围设置</text>
        <view class="mpro-modal-close" bindtap="onCloseDeliveryModal">×</view>
      </view>
      <view class="mpro-modal-body">
        <text class="mpro-modal-desc">设置配送半径，超出范围的用户将被引导选择到店自取。</text>
        <view class="mpro-modal-field">
          <text class="mpro-modal-label">配送半径</text>
          <view class="mpro-modal-input-row">
            <input
              class="mpro-modal-input"
              type="digit"
              maxlength="4"
              value="{{deliveryRadiusInput}}"
              bindinput="onDeliveryRadiusInput"
              placeholder="请输入公里数"
            />
            <text class="mpro-modal-unit">公里</text>
          </view>
        </view>
        <text class="mpro-modal-hint">支持 1-50 公里范围</text>
      </view>
      <view class="mpro-modal-foot">
        <button class="mpro-modal-cancel" bindtap="onCloseDeliveryModal">取消</button>
        <button class="mpro-modal-save" bindtap="onSaveDelivery" loading="{{savingDelivery}}">保存</button>
      </view>
    </view>
  </view>

  <!-- ============================================================ -->
  <!-- 营业时间弹窗 -->
  <!-- ============================================================ -->
  <view class="mpro-modal-mask" wx:if="{{showBusinessHoursModal}}" bindtap="onCloseBusinessHoursModal">
    <view class="mpro-modal-card" catchtap="onPreventClose">
      <view class="mpro-modal-head">
        <text class="mpro-modal-title">营业时间设置</text>
        <view class="mpro-modal-close" bindtap="onCloseBusinessHoursModal">×</view>
      </view>
      <view class="mpro-modal-body">
        <text class="mpro-modal-desc">设置每日营业时间，顾客端将据此限制预约时段和下单时间。</text>

        <!-- 开始时间 -->
        <view class="mpro-modal-field-block">
          <text class="mpro-modal-label">开始营业</text>
          <picker mode="time" value="{{openTimeDisplay}}" bindchange="onOpenTimeChange">
            <view class="mpro-time-picker">
              <text class="mpro-time-value">{{openTimeDisplay}}</text>
              <text class="mpro-arrow">›</text>
            </view>
          </picker>
        </view>

        <!-- 结束时间 -->
        <view class="mpro-modal-field-block">
          <text class="mpro-modal-label">结束营业</text>
          <picker mode="time" value="{{closeTimeDisplay}}" bindchange="onCloseTimeChange">
            <view class="mpro-time-picker">
              <text class="mpro-time-value">{{closeTimeDisplay}}</text>
              <text class="mpro-arrow">›</text>
            </view>
          </picker>
        </view>

        <text class="mpro-modal-hint">顾客可在 {{openTimeDisplay}} 至 {{closeTimeDisplay}} 时段内下单和预约取货</text>
      </view>
      <view class="mpro-modal-foot">
        <button class="mpro-modal-cancel" bindtap="onCloseBusinessHoursModal">取消</button>
        <button class="mpro-modal-save" bindtap="onSaveBusinessHours" loading="{{savingHours}}">保存</button>
      </view>
    </view>
  </view>

  <!-- ==================== 打印机连接面板 ==================== -->
  <view class="md-overlay" wx:if="{{showPrinterPanel}}" catchtap="onClosePrinterPanel">
    <view class="md-modal" catchtap="onPreventClose">
      <view class="printer-header">
        <text class="printer-title">连接蓝牙打印机</text>
        <text class="printer-close" bindtap="onClosePrinterPanel">✕</text>
      </view>

      <!-- 当前连接状态 -->
      <view class="printer-connected-bar" wx:if="{{connectedPrinterId && !printerSearching && !printerConnecting}}">
        <text class="printer-connected-icon">🔗</text>
        <text class="printer-connected-text">{{connectedPrinterName || connectedPrinterId}}</text>
        <text class="printer-disconnect-btn" bindtap="onDisconnectPrinter">断开</text>
      </view>

      <!-- 搜索中 -->
      <view class="printer-searching" wx:if="{{printerSearching}}">
        <view class="printer-spinner"></view>
        <text class="printer-searching-text">正在搜索附近的蓝牙打印机...</text>
      </view>

      <!-- 连接中 -->
      <view class="printer-status" wx:if="{{printerConnecting}}">
        <text class="printer-connecting-icon">⏳</text>
        <text class="printer-connecting-text">正在连接 {{currentPrinter.name || '打印机'}}...</text>
      </view>

      <!-- 打印机列表 -->
      <scroll-view
        class="printer-list"
        scroll-y
        enhanced
        show-scrollbar="{{false}}"
        wx:if="{{!printerSearching && !printerConnecting}}"
      >
        <block wx:if="{{printers.length > 0}}">
          <view
            class="printer-item"
            wx:for="{{printers}}"
            wx:key="deviceId"
            data-device-id="{{item.deviceId}}"
            data-device-name="{{item.name}}"
            bindtap="onSelectPrinterProfile"
          >
            <view class="printer-item-left">
              <text class="printer-icon">🖨</text>
              <view class="printer-info">
                <text class="printer-name">{{item.name}}</text>
                <text class="printer-id">{{item.deviceId}}</text>
              </view>
            </view>
            <view class="printer-item-right">
              <text class="printer-signal">{{item.RSSI >= -50 ? '📶' : item.RSSI >= -70 ? '📶' : '📶'}}</text>
              <text class="printer-connect-hint">连接 ›</text>
            </view>
          </view>
        </block>

        <view class="printer-empty" wx:if="{{printers.length === 0}}">
          <text class="printer-empty-icon">🔍</text>
          <text class="printer-empty-text">没有发现打印机</text>
          <text class="printer-empty-hint">请确认：\n1. 打印机已开机\n2. 手机蓝牙已开启\n3. 打印机在手机附近（10米内）</text>
          <button class="printer-rescan-btn" bindtap="onSearchPrinters">🔄 重新搜索</button>
        </view>
      </scroll-view>

      <view class="printer-footer" wx:if="{{!printerSearching && !printerConnecting}}">
        <button class="printer-rescan-btn" bindtap="onSearchPrinters">🔄 重新搜索</button>
      </view>
    </view>
  </view>

  <custom-tab-bar current="profile" theme="merchant" bind:change="onTabChange" />
</view>
