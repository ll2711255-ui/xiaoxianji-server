@import '../../../utils/printer-panel.wxss';

.mpro-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.mpro-scroll {
  flex: 1;
  height: 0;
}

/* Header */
.mpro-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
  padding: 32rpx 32rpx 40rpx;
  gap: 20rpx;
}
.mpro-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.mpro-shop-info {
  flex: 1;
}
.mpro-shop-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: #fff;
  display: block;
}
.mpro-shop-id {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.4);
  margin-top: 4rpx;
  display: block;
}
.mpro-role-tag {
  background: rgba(255,255,255,0.15);
  color: #fff;
  font-size: var(--font-sm);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-lg);
}

/* Section */
.mpro-sec-title {
  font-size: var(--font-md);
  color: var(--color-text-3);
  display: block;
  margin-bottom: 8rpx;
}

/* Menu item */
.mpro-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
}
.mpro-item + .mpro-item {
  border-top: 1rpx solid var(--color-border);
}
.mpro-item:active {
  opacity: 0.6;
}
.mpro-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: var(--font-lg);
  color: var(--color-text-1);
}
.mpro-item-icon {
  font-size: var(--font-xl);
}
.mpro-arrow {
  font-size: var(--font-xl);
  color: var(--color-text-3);
}

/* Logout */
.mpro-logout-wrap {
  padding: 48rpx 24rpx;
  text-align: center;
}
.mpro-logout-btn {
  width: 100%;
  background: var(--color-bg-card);
  color: var(--color-danger);
  border: 1rpx solid var(--color-danger);
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  padding: 20rpx 0;
}
.mpro-version {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-3);
  margin-top: 24rpx;
}

/* ====================================================================
   配送设置弹窗
   ==================================================================== */
.mpro-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1001;
  display: flex;
  align-items: center;
  justify-content: center;
}
.mpro-modal-card {
  width: 600rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.mpro-modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}
.mpro-modal-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-1);
}
.mpro-modal-close {
  font-size: 48rpx;
  color: var(--color-text-3);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.mpro-modal-body {
  padding: 0 32rpx 24rpx;
}
.mpro-modal-desc {
  font-size: var(--font-base);
  color: var(--color-text-3);
  line-height: 1.6;
  display: block;
  margin-bottom: 28rpx;
}
.mpro-modal-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
}
.mpro-modal-label {
  font-size: var(--font-base);
  color: var(--color-text-1);
  flex-shrink: 0;
}
.mpro-modal-input-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.mpro-modal-input {
  width: 120rpx;
  height: 64rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-1);
}
.mpro-modal-unit {
  font-size: var(--font-base);
  color: var(--color-text-2);
}
.mpro-modal-hint {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  margin-top: 12rpx;
  display: block;
}
.mpro-modal-foot {
  display: flex;
  border-top: 1rpx solid var(--color-border);
}
.mpro-modal-cancel,
.mpro-modal-save {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: var(--font-lg);
  background: var(--color-bg-card);
  border: none;
  border-radius: 0;
  padding: 0;
}
.mpro-modal-cancel {
  color: var(--color-text-3);
  border-right: 1rpx solid var(--color-border);
}
.mpro-modal-save {
  color: var(--color-primary);
  font-weight: 600;
}
.mpro-modal-cancel::after,
.mpro-modal-save::after {
  display: none;
}

/* 店铺信息弹窗 — 整行输入框 */
.mpro-modal-field-block {
  margin-bottom: 28rpx;
}
.mpro-modal-input-full {
  width: 100%;
  height: 80rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 0 24rpx;
  font-size: var(--font-base);
  color: var(--color-text-1);
  box-sizing: border-box;
  margin-top: 12rpx;
}

/* 地址选择行 */
.mpro-addr-row {
  display: flex;
  align-items: center;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  margin-top: 12rpx;
}
.mpro-addr-text {
  flex: 1;
  font-size: var(--font-base);
  color: var(--color-text-1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mpro-addr-placeholder {
  color: var(--color-text-3);
}
.mpro-addr-pin {
  flex-shrink: 0;
  font-size: var(--font-base);
  color: var(--color-primary);
  font-weight: 600;
  margin-left: 16rpx;
  padding: 8rpx 0;
}
.mpro-addr-pin:active {
  opacity: 0.6;
}

/* 地图预览 */
.mpro-map-wrap {
  margin-top: 20rpx;
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}
.mpro-map {
  width: 100%;
  height: 100%;
}
