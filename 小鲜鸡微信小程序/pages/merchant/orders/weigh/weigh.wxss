@import '../../../../utils/printer-panel.wxss';

/* ========== 商家称重页面 ========== */
.mw-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* 页面头部 */
.mw-header {
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
  padding: 36rpx 32rpx;
  text-align: center;
}
.mw-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: #fff;
  display: block;
}
.mw-order-no {
  font-size: var(--font-base);
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
  font-weight: 500;
}

.mw-section-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-1);
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

/* 商品信息 */
.mw-product-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}
.mw-product-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-1);
}
.mw-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}
.mw-tag {
  font-size: var(--font-sm);
  color: var(--color-text-2);
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  padding: 4rpx 14rpx;
}

/* 信息行 */
.mw-inforow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}
.mw-inforow + .mw-inforow {
  border-top: 1rpx solid var(--color-border);
}
.mw-infol {
  font-size: var(--font-base);
  color: var(--color-text-2);
  flex-shrink: 0;
}
.mw-infor {
  font-size: var(--font-base);
  color: var(--color-text-1);
  font-weight: 500;
  text-align: right;
}
.mw-price {
  color: var(--color-primary);
  font-weight: 700;
}
.mw-prepay-row {
  margin-top: 6rpx;
}
.mw-prepay {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-primary);
}

/* 退款行 */
.mw-refund-row {
  background: var(--color-success-bg);
  border-radius: var(--radius-md);
  padding: 14rpx 16rpx;
  margin-top: 4rpx;
}
.mw-refund {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-success);
}
.mw-no-refund-row {
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 14rpx 16rpx;
  margin-top: 4rpx;
}
.mw-no-refund {
  color: var(--color-text-3);
  font-size: var(--font-base);
}

/* 重量输入 */
.mw-weight-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.mw-weight-input {
  flex: 1;
  border: 2rpx solid var(--color-warning);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-1);
  text-align: center;
  letter-spacing: 8rpx;
}
.mw-weight-unit {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-warning);
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}
.mw-input-hint {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  display: block;
  margin-top: 14rpx;
  text-align: center;
}

/* 约束标签 */
.mw-constraint-label {
  font-size: var(--font-md);
  color: var(--color-warning);
  display: block;
  margin-top: 14rpx;
  text-align: center;
  font-weight: 500;
}

/* 输入框警告态 */
.mw-weight-input.warn {
  border-color: var(--color-danger);
  background: var(--color-primary-pale);
}

/* 校验警告文字 */
.mw-weight-warning {
  margin-top: 14rpx;
  text-align: center;
  font-size: var(--font-md);
  color: var(--color-danger);
  font-weight: 500;
}

/* 照片上传 */
.mw-photo-area {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--color-bg-page);
}
.mw-photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.mw-photo-icon {
  font-size: 60rpx;
}
.mw-photo-text {
  font-size: var(--font-base);
  color: var(--color-text-3);
}

.mw-photo-preview {
  position: relative;
}
.mw-photo-img {
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
}
.mw-photo-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}
.mw-photo-btn {
  flex: 1;
  border: none;
  border-radius: var(--radius-xl);
  font-size: var(--font-md);
  padding: 14rpx 0;
  text-align: center;
}
.mw-photo-repick {
  background: var(--color-bg-page);
  color: var(--color-text-2);
}
.mw-photo-remove {
  background: var(--color-primary-pale);
  color: var(--color-danger);
}

/* 提交按钮 */
.mw-submit-wrap {
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.mw-submit-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-yolk));
  color: #fff;
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-lg);
  font-weight: 700;
  padding: 26rpx 0;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(245,166,35,0.40);
}
.mw-submit-btn[disabled] {
  background: #D1D1D1;
  color: var(--color-text-3);
}

/* 共用卡片样式 */
.card-full {
  margin: 16rpx 20rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
}

/* ========== 号码牌选择（与线下收银一致） ========== */
.mw-card-scroll {
  max-height: 420rpx;
  overflow-y: auto;
}
.mw-card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}
.mw-card-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}
.mw-card-item.idle {
  background: var(--color-success);
  border-color: var(--color-success);
}
.mw-card-item.used {
  background: #CCCCCC;
  border-color: var(--color-border);
}
.mw-card-item.selected {
  border: 4rpx solid var(--color-warning);
  box-shadow: 0 4rpx 16rpx rgba(255,149,0,0.35);
  transform: scale(1.12);
  position: relative;
  z-index: 2;
}
.mw-card-num-text {
  font-size: var(--font-lg);
  font-weight: 800;
  color: #FFFFFF;
}
.mw-no-card {
  font-size: var(--font-md);
  color: var(--color-danger);
  text-align: center;
  padding: 24rpx 0;
  display: block;
}
.mw-card-hint {
  font-size: var(--font-sm);
  color: var(--color-primary);
  text-align: center;
  display: block;
  margin-top: 16rpx;
  font-weight: 500;
}
.mw-card-optional {
  color: var(--color-text-3);
  font-weight: 400;
}

/* ========== 弹窗 & 打印面板（复用 detail 样式） ========== */
.md-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.md-modal {
  width: 85vw;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.md-modal-title {
  font-size: var(--font-lg);
  font-weight: 700;
  display: block;
  text-align: center;
  margin-bottom: 28rpx;
}
.md-modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.md-modal-cancel, .md-modal-confirm {
  flex: 1;
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  padding: 20rpx 0;
}
.md-modal-cancel {
  background: var(--color-bg-page);
  color: var(--color-text-3);
}
.md-modal-confirm {
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

/* 打印机列表项 */
.printer-item {
  display: flex;
  align-items: center;
  padding: 22rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.printer-item-left { flex: 1; }
.printer-name { font-size: var(--font-base); color: var(--color-text-1); display: block; }
.printer-rssi { font-size: var(--font-sm); color: var(--color-text-3); margin-top: 4rpx; display: block; }
.printer-arrow { font-size: var(--font-lg); color: var(--color-text-3); }

/* ========== 小票预览（模拟打印） ========== */
.ticket-preview-modal {
  max-width: 600rpx;
}
.ticket-paper {
  background: #FFFEF7;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  padding: 24rpx 20rpx;
  font-family: monospace;
  font-size: var(--font-sm);
  color: var(--color-text-1);
  line-height: 1.8;
  margin-bottom: 20rpx;
}
.ticket-center { text-align: center; }
.ticket-shop { font-size: var(--font-xl); font-weight: 800; display: block; }
.ticket-sub { font-size: var(--font-sm); color: var(--color-text-3); display: block; margin-top: 4rpx; }
.ticket-divider { font-size: var(--font-xs); color: var(--color-text-3); display: block; margin: 8rpx 0; letter-spacing: 2rpx; }
.ticket-row { display: flex; padding: 2rpx 0; }
.ticket-label { color: var(--color-text-2); flex-shrink: 0; }
.ticket-card-no { font-weight: 800; color: var(--color-primary); font-size: var(--font-base); }
.ticket-amount-block { margin: 16rpx 0; }
.ticket-amount { font-size: 52rpx; font-weight: 800; color: var(--color-primary); display: block; }
.ticket-amount-label { font-size: var(--font-sm); color: var(--color-text-3); display: block; }
.ticket-refund { font-size: var(--font-sm); color: var(--color-success); display: block; }
.ticket-qr { width: 180rpx; height: 180rpx; margin: 10rpx auto; display: block; }
.ticket-qr-placeholder { font-size: var(--font-sm); color: var(--color-text-3); display: block; padding: 60rpx 0; }
.ticket-qr-hint { font-size: var(--font-xs); color: var(--color-text-3); display: block; }
.ticket-time { font-size: var(--font-sm); color: var(--color-text-3); display: block; }
.ticket-thanks { font-size: var(--font-xs); color: var(--color-text-3); display: block; margin-top: 4rpx; }
