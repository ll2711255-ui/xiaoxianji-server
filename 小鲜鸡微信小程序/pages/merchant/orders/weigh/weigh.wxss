@import '../../../../utils/printer-panel.wxss';

/* ========== 商家称重页面 ========== */
.mw-page {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 页面头部 */
.mw-header {
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
  padding: 36rpx 32rpx;
  text-align: center;
}
.mw-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}
.mw-order-no {
  font-size: 30rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  display: block;
  font-weight: 500;
}

.mw-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

/* 商品信息 */
.mw-product-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}
.mw-product-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}
.mw-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}
.mw-tag {
  font-size: 26rpx;
  color: #666;
  background: #F0F0F0;
  border-radius: 6rpx;
  padding: 4rpx 14rpx;
}

/* 信息行 */
.mw-inforow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}
.mw-inforow + .mw-inforow {
  border-top: 1rpx solid #F8F8F8;
}
.mw-infol {
  font-size: 30rpx;
  color: #666;
  flex-shrink: 0;
}
.mw-infor {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 500;
  text-align: right;
}
.mw-price {
  color: #FF4B26;
  font-weight: 700;
}
.mw-prepay-row {
  margin-top: 6rpx;
}
.mw-prepay {
  font-size: 34rpx;
  font-weight: 700;
  color: #FF5722;
}

/* 退款行 */
.mw-refund-row {
  background: #F6FFED;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  margin-top: 4rpx;
}
.mw-refund {
  font-size: 34rpx;
  font-weight: 700;
  color: #34C759;
}
.mw-no-refund-row {
  background: #FAFAFA;
  border-radius: 8rpx;
  padding: 14rpx 16rpx;
  margin-top: 4rpx;
}
.mw-no-refund {
  color: #B0B0B0;
  font-size: 30rpx;
}

/* 重量输入 */
.mw-weight-input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.mw-weight-input {
  flex: 1;
  border: 2rpx solid #FF9500;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  letter-spacing: 8rpx;
}
.mw-weight-unit {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9500;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}
.mw-input-hint {
  font-size: 26rpx;
  color: #B0B0B0;
  display: block;
  margin-top: 14rpx;
  text-align: center;
}

/* 约束标签 */
.mw-constraint-label {
  font-size: 28rpx;
  color: #FF9500;
  display: block;
  margin-top: 14rpx;
  text-align: center;
  font-weight: 500;
}

/* 输入框警告态 */
.mw-weight-input.warn {
  border-color: #FF3B30;
  background: #FFF5F5;
}

/* 校验警告文字 */
.mw-weight-warning {
  margin-top: 14rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FF3B30;
  font-weight: 500;
}

/* 照片上传 */
.mw-photo-area {
  width: 100%;
  height: 300rpx;
  border: 2rpx dashed #E0E0E0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #FAFAFA;
}
.mw-photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.mw-photo-icon {
  font-size: 60rpx;
}
.mw-photo-text {
  font-size: 30rpx;
  color: #B0B0B0;
}

.mw-photo-preview {
  position: relative;
}
.mw-photo-img {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
}
.mw-photo-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
}
.mw-photo-btn {
  flex: 1;
  border: none;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 14rpx 0;
  text-align: center;
}
.mw-photo-repick {
  background: #F0F0F0;
  color: #666;
}
.mw-photo-remove {
  background: #FFF2F0;
  color: #FF3B30;
}

/* 提交按钮 */
.mw-submit-wrap {
  padding: 32rpx 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.mw-submit-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-yolk));
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 36rpx;
  font-weight: 700;
  padding: 26rpx 0;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 20rpx rgba(245,166,35,0.40);
}
.mw-submit-btn[disabled] {
  background: #D1D1D1;
  color: #999;
}

/* 共用卡片样式 */
.card-full {
  margin: 16rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
}

/* ========== 号码牌选择（与线下收银一致） ========== */
.mw-card-scroll {
  max-height: 420rpx;
  overflow-y: auto;
}
.mw-card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}
.mw-card-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}
.mw-card-item.idle {
  background: #4CAF50;
  border-color: #4CAF50;
}
.mw-card-item.used {
  background: #CCCCCC;
  border-color: #CCCCCC;
}
.mw-card-item.selected {
  border: 4rpx solid #FF9500;
  box-shadow: 0 4rpx 16rpx rgba(255,149,0,0.35);
  transform: scale(1.12);
  position: relative;
  z-index: 2;
}
.mw-card-num-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
}
.mw-no-card {
  font-size: 28rpx;
  color: #FF3B30;
  text-align: center;
  padding: 24rpx 0;
  display: block;
}
.mw-card-hint {
  font-size: 26rpx;
  color: #FF5722;
  text-align: center;
  display: block;
  margin-top: 16rpx;
  font-weight: 500;
}
.mw-card-optional {
  color: #B0B0B0;
  font-weight: 400;
}

/* ========== 弹窗 & 打印面板（复用 detail 样式） ========== */
.md-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.md-modal {
  width: 85vw;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.md-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  text-align: center;
  margin-bottom: 28rpx;
}
.md-modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.md-modal-cancel, .md-modal-confirm {
  flex: 1;
  border: none;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}
.md-modal-cancel {
  background: #F5F5F5;
  color: #999;
}
.md-modal-confirm {
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

/* 打印机列表项 */
.printer-item {
  display: flex;
  align-items: center;
  padding: 22rpx 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}
.printer-item-left { flex: 1; }
.printer-name { font-size: 30rpx; color: #1A1A1A; display: block; }
.printer-rssi { font-size: 24rpx; color: #B0B0B0; margin-top: 4rpx; display: block; }
.printer-arrow { font-size: 36rpx; color: #CCC; }

/* ========== 小票预览（模拟打印） ========== */
.ticket-preview-modal {
  max-width: 600rpx;
}
.ticket-paper {
  background: #FFFEF7;
  border: 2rpx dashed #E0DCC8;
  border-radius: 8rpx;
  padding: 24rpx 20rpx;
  font-family: monospace;
  font-size: 26rpx;
  color: #1A1A1A;
  line-height: 1.8;
  margin-bottom: 20rpx;
}
.ticket-center { text-align: center; }
.ticket-shop { font-size: 40rpx; font-weight: 800; display: block; }
.ticket-sub { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }
.ticket-divider { font-size: 22rpx; color: #CCC; display: block; margin: 8rpx 0; letter-spacing: 2rpx; }
.ticket-row { display: flex; padding: 2rpx 0; }
.ticket-label { color: #666; flex-shrink: 0; }
.ticket-card-no { font-weight: 800; color: #FF5722; font-size: 32rpx; }
.ticket-amount-block { margin: 16rpx 0; }
.ticket-amount { font-size: 52rpx; font-weight: 800; color: #FF4B26; display: block; }
.ticket-amount-label { font-size: 24rpx; color: #999; display: block; }
.ticket-refund { font-size: 26rpx; color: #34C759; display: block; }
.ticket-qr { width: 180rpx; height: 180rpx; margin: 10rpx auto; display: block; }
.ticket-qr-placeholder { font-size: 24rpx; color: #CCC; display: block; padding: 60rpx 0; }
.ticket-qr-hint { font-size: 22rpx; color: #B0B0B0; display: block; }
.ticket-time { font-size: 24rpx; color: #999; display: block; }
.ticket-thanks { font-size: 22rpx; color: #CCC; display: block; margin-top: 4rpx; }
