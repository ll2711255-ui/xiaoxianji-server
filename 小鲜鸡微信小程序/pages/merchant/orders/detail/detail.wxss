@import '../../../../utils/printer-panel.wxss';

/* ========== 商家订单详情 ========== */
.md-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* 头部 */
.md-header {
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
  padding: 40rpx 32rpx;
  text-align: center;
}
.md-status {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}
.md-no {
  font-size: var(--font-md);
  color: rgba(255,255,255,0.6);
  margin-top: 8rpx;
  display: block;
}
.md-type {
  font-size: var(--font-sm);
  color: rgba(255,255,255,0.4);
  margin-top: 4rpx;
  display: block;
}

.md-section-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-1);
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

/* 商品 */
.md-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}
.md-item + .md-item { border-top: 1rpx solid var(--color-border); }
.md-item-left { flex: 1; }
.md-pname { font-size: var(--font-base); font-weight: 500; color: var(--color-text-1); display: block; }
.md-ptags { display: flex; gap: 8rpx; margin-top: 8rpx; }
.md-item-right { text-align: right; flex-shrink: 0; margin-left: 16rpx; }
.md-pqty { font-size: var(--font-md); color: var(--color-text-3); display: block; }
.md-pprice { font-size: var(--font-base); font-weight: 700; color: var(--color-primary); margin-top: 6rpx; display: block; }

.md-card-num {
  font-weight: 800;
  color: var(--color-primary);
  font-size: var(--font-lg);
}

.weigh-photo-hint {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  display: block;
  text-align: center;
  margin-top: 8rpx;
}

/* 称重照片 */
.md-weigh-img {
  width: 100%;
  max-width: 500rpx;
  height: 400rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
  display: block;
  margin: 0 auto;
}

/* 操作按钮 */
.md-actions {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.md-action-btn {
  width: 100%;
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-lg);
  font-weight: 600;
  padding: 24rpx 0;
  margin-bottom: 16rpx;
  color: #fff;
}
.md-accept { background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red)); box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow); }
.md-weigh { background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-yolk)); box-shadow: 0 4rpx 12rpx rgba(245,166,35,0.35); }
.md-process { background: var(--color-brand-tangerine); }
.md-deliver { background: var(--color-brand-amber); }
.md-ready { background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-yolk)); box-shadow: 0 4rpx 12rpx rgba(245,166,35,0.35); }
.md-done { background: var(--color-text-3); }
.md-pickup { background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-yolk)); box-shadow: 0 4rpx 12rpx rgba(245,166,35,0.35); }
.md-cancel { background: #fff; color: var(--color-danger); border: 2rpx solid var(--color-danger); }
.md-pay { background: var(--color-success); }

/* 弹窗 */
.md-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.md-modal {
  width: 85vw;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
}
.md-modal-title {
  font-size: var(--font-lg);
  font-weight: 700;
  display: block;
  text-align: center;
  margin-bottom: 28rpx;
}

/* 称重表单 */
.md-form-row {
  margin-bottom: 24rpx;
}
.md-form-label {
  font-size: var(--font-base);
  color: var(--color-text-2);
  display: block;
  margin-bottom: 10rpx;
}
.md-form-input {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 16rpx;
  font-size: var(--font-base);
  width: 100%;
  box-sizing: border-box;
}
.md-photo-area {
  width: 100%;
  height: 240rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.md-photo-preview {
  width: 100%;
  height: 100%;
}
.md-photo-placeholder {
  font-size: var(--font-base);
  color: var(--color-text-3);
}

/* 称重内联表单 */
.wi-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.wi-input {
  flex: 1;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 16rpx;
  font-size: var(--font-base);
}
.wi-unit {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-primary);
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}
.wi-photo {
  width: 100%;
  height: 280rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: var(--color-bg-page);
}
.wi-photo-img {
  width: 100%;
  height: 100%;
}
.wi-photo-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.wi-photo-icon {
  font-size: 56rpx;
}
.wi-photo-text {
  font-size: var(--font-md);
  color: var(--color-text-3);
}

.md-modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}
.md-modal-cancel, .md-modal-confirm {
  flex: 1;
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  padding: 20rpx 0;
}
.md-modal-cancel {
  background: var(--color-bg-page);
  color: var(--color-text-3);
}
.md-modal-confirm {
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

/* 号码牌网格 */
.md-card-scroll {
  max-height: 420rpx;
  overflow-y: auto;
}
.md-card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}
.md-card-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}
.md-card-item.idle {
  background: var(--color-success);
  border-color: var(--color-success);
}
.md-card-item.used {
  background: #CCCCCC;
  border-color: var(--color-border);
}
.md-card-item.selected {
  border: 4rpx solid var(--color-warning);
  box-shadow: 0 4rpx 16rpx rgba(255,149,0,0.35);
  transform: scale(1.12);
  position: relative;
  z-index: 2;
}
.md-card-num-text {
  font-size: var(--font-lg);
  font-weight: 800;
  color: #FFFFFF;
}

/* ========== 订单信息行 ========== */
.od-inforow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  font-size: var(--font-base);
}
.od-infol {
  color: var(--color-text-3);
  flex-shrink: 0;
}
.od-infor {
  color: var(--color-text-1);
  flex: 1;
  text-align: right;
}
.od-price {
  color: var(--color-primary);
  font-weight: 700;
}
.od-addr {
  text-align: right;
}

/* 可点击行（地址导航 / 电话拨号） */
.od-tappable {
  cursor: pointer;
}
.od-tappable:active {
  background: var(--color-bg-page);
  margin: 0 -32rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
}
.od-link {
  color: var(--color-primary);
  font-weight: 500;
}
.od-arrow {
  font-size: var(--font-lg);
  color: var(--color-text-3);
  margin-left: 8rpx;
  flex-shrink: 0;
}
.od-copy-btn {
  font-size: var(--font-base);
  padding: 6rpx 12rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
}
.od-copy-btn:active {
  background: #D0D0D0;
}
