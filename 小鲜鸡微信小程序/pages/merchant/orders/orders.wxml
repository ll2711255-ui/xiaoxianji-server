<view class="mo-page">
  <!-- 顶部切换：线上 / 线下 -->
  <view class="mo-segment">
    <view class="mo-seg-item {{segment === 'online' ? 'on' : ''}}" data-seg="online" bindtap="onSegmentTap">
      <text>线上订单</text>
    </view>
    <view class="mo-seg-item {{segment === 'offline' ? 'on' : ''}}" data-seg="offline" bindtap="onSegmentTap">
      <text>线下订单</text>
    </view>
  </view>

  <!-- ==================== 线上订单 ==================== -->
  <block wx:if="{{segment === 'online'}}">
    <!-- Stats bar -->
    <view class="mo-stats-bar">
      <view class="mo-stat" wx:for="{{statCards}}" wx:key="key">
        <text class="mo-stat-num">{{item.count}}</text>
        <text class="mo-stat-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 子 Tab -->
    <view class="mo-tabs">
      <view
        class="mo-tab {{tabIndex === index ? 'on' : ''}}"
        wx:for="{{tabs}}"
        wx:key="*this"
        data-index="{{index}}"
        bindtap="onTabTap"
      >{{item}}</view>
    </view>

    <!-- 配送/待取货 子 Tab -->
    <view class="mo-sub-tabs" wx:if="{{tabIndex === 3}}">
      <view
        class="mo-sub-tab {{deliverySubTab === 0 ? 'on' : ''}}"
        data-index="0"
        bindtap="onDeliverySubTabTap"
      >配送订单</view>
      <view
        class="mo-sub-tab {{deliverySubTab === 1 ? 'on' : ''}}"
        data-index="1"
        bindtap="onDeliverySubTabTap"
      >自取订单</view>
    </view>

    <!-- 订单列表 -->
    <scroll-view class="mo-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="mo-body" wx:if="{{orders.length > 0}}">
        <view
          class="mo-card {{item.canAccept ? 'mo-card-new' : ''}}"
          wx:for="{{orders}}"
          wx:key="_id"
          data-order-no="{{item.orderNo}}"
          bindtap="onOrderTap"
        >
          <view class="mo-head">
            <view class="mo-head-left">
              <text class="mo-no">{{item.orderNo}}</text>
              <text class="mo-type-tag">{{item.typeLabel}}</text>
              <text class="mo-time" wx:if="{{item.timeAgo}}">{{item.timeAgo}}</text>
            </view>
            <text class="mo-status {{item.canAccept ? 'mo-status-warn' : item.status === 'cancelled' ? 'mo-status-cancel' : 'mo-status-ok'}}">{{item.statusText}}</text>
          </view>

          <view class="mo-items">
            <view class="mo-item" wx:for="{{item.items}}" wx:for-item="p" wx:key="productId">
              <text class="mo-pname">{{p.productName}}</text>
              <text class="mo-pspec" wx:if="{{p.spec}}">{{p.spec.type || ''}}{{p.spec.weight ? ' ' + p.spec.weight : ''}} {{p.spec.processing || ''}}</text>
              <text class="mo-pqty">×{{p.quantity}}</text>
            </view>
          </view>

          <view class="mo-item" wx:if="{{item.cardNumber}}">
            <text class="mo-pname">号码牌</text>
            <text class="mo-pspec">#{{item.cardNumber}}</text>
          </view>

          <view class="mo-distance" wx:if="{{item.distance > 0}}">
            <text class="mo-distance-text">配送距离 {{item.distanceDisplay}}</text>
          </view>

          <view class="mo-refund-info" wx:if="{{item.canRetryRefund}}">
            <text class="mo-refund-amount">应退：¥{{item.refundDisplay}}</text>
          </view>

          <view class="mo-foot">
            <text class="mo-amount">¥{{item.prepayDisplay}}</text>
            <view class="mo-actions">
              <button class="mo-btn mo-btn-retry-refund" wx:if="{{item.canRetryRefund}}" data-order-no="{{item.orderNo}}" data-action="retryRefund" catchtap="onAction">重新退款</button>
              <button class="mo-btn mo-btn-accept" wx:if="{{item.canAccept}}" data-order-no="{{item.orderNo}}" data-action="accept" catchtap="onAction">接单</button>
              <button class="mo-btn mo-btn-reject" wx:if="{{item.canReject}}" data-order-no="{{item.orderNo}}" catchtap="onReject">拒单</button>
              <button class="mo-btn mo-btn-weigh" wx:if="{{item.canWeigh}}" data-order-no="{{item.orderNo}}" data-action="weigh" catchtap="onAction">称重</button>
              <button class="mo-btn mo-btn-process" wx:if="{{item.canProcess}}" data-order-no="{{item.orderNo}}" data-action="process" catchtap="onAction">开始处理</button>
              <button class="mo-btn mo-btn-process" wx:if="{{item.canProcessDone}}" data-order-no="{{item.orderNo}}" data-action="ready" catchtap="onAction">处理完成</button>
              <button class="mo-btn mo-btn-deliver" wx:if="{{item.canDeliver}}" data-order-no="{{item.orderNo}}" data-action="deliver" catchtap="onAction">开始配送</button>
              <button class="mo-btn mo-btn-pickup" wx:if="{{item.canPickup}}" data-order-no="{{item.orderNo}}" data-action="complete" catchtap="onAction">已取货</button>
              <button class="mo-btn mo-btn-arrive" wx:if="{{item.canComplete && item.status === 'delivering'}}" data-order-no="{{item.orderNo}}" data-action="complete" catchtap="onAction">配送完成</button>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-state" wx:if="{{orders.length === 0 && !loading}}">
        <text class="empty-icon">📋</text>
        <text>暂无订单</text>
      </view>
      <view class="load-more" wx:if="{{loading}}">加载中...</view>
      <view style="height: 140rpx;"></view>
    </scroll-view>
  </block>

  <!-- ==================== 线下订单 ==================== -->
  <block wx:if="{{segment === 'offline'}}">
    <!-- Stats bar -->
    <view class="mo-stats-bar">
      <view class="mo-stat" wx:for="{{offlineStats}}" wx:key="key">
        <text class="mo-stat-num">{{item.count}}</text>
        <text class="mo-stat-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 子 Tab -->
    <view class="mo-tabs">
      <view
        class="mo-tab {{offlineTabIndex === index ? 'on' : ''}}"
        wx:for="{{offlineTabs}}"
        wx:key="*this"
        data-index="{{index}}"
        bindtap="onOfflineTabTap"
      >{{item}}</view>
    </view>

    <!-- ===== Tab 0：收银 ===== -->
    <scroll-view class="mo-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:if="{{offlineTabIndex === 0}}">
      <!-- 成功结果 -->
      <view class="mof-result" wx:if="{{offlineResult}}">
        <text class="mof-check">✓</text>
        <text class="mof-result-title">收款成功</text>
        <view class="mof-result-card">
          <view class="mof-result-row">
            <text class="mof-result-l">订单编号</text>
            <text class="mof-result-v">{{offlineResult.orderNo}}</text>
          </view>
          <view class="mof-result-row">
            <text class="mof-result-l">号码牌</text>
            <text class="mof-result-v mof-result-num">{{offlineResult.cardNumber}}</text>
          </view>
          <view class="mof-result-row">
            <text class="mof-result-l">金额</text>
            <text class="mof-result-v mof-result-price">¥{{offlineAmountDisplay}}</text>
          </view>
        </view>
        <view class="mof-result-btns">
          <button class="mof-result-btn" bindtap="onPrintReceipt">🖨 打印小票</button>
          <button class="mof-result-btn" bindtap="onOfflineNewOrder">继续收银</button>
        </view>
      </view>

      <!-- 收银表单 -->
      <view wx:else>
        <!-- 金额显示（点击弹出计算器） -->
        <view class="mof-amount-area" bindtap="onOpenCalculator">
          <text class="mof-currency">¥</text>
          <text class="mof-amount">{{offlineAmountDisplay}}</text>
          <text class="mof-amount-hint">点击输入金额</text>
        </view>

        <!-- 付款方式 -->
        <view class="mof-section">
          <text class="mof-section-title">付款方式</text>
          <view class="mof-pay-types">
            <view class="mof-pay-type {{offlinePaymentType === 'cash' ? 'on' : ''}}" data-type="cash" bindtap="onOfflinePaymentType">
              <text>现金/扫码</text>
            </view>
            <view class="mof-pay-type {{offlinePaymentType === 'wechat' ? 'on' : ''}}" data-type="wechat" bindtap="onOfflinePaymentType">
              <text>微信</text>
            </view>
            <view class="mof-pay-type {{offlinePaymentType === 'unpaid' ? 'on' : ''}}" data-type="unpaid" bindtap="onOfflinePaymentType">
              <text>未支付</text>
            </view>
          </view>
        </view>

        <!-- 号码牌选择 -->
        <view class="mof-section">
          <text class="mof-section-title">选择挂牌号码</text>
          <scroll-view class="md-card-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:if="{{offlineCardNumbers.length > 0}}">
            <view class="md-card-grid">
              <view
                class="md-card-item {{card.status === 'idle' ? 'idle' : 'used'}} {{offlineSelectedCard === card.number ? 'selected' : ''}}"
                wx:for="{{offlineCardNumbers}}"
                wx:for-item="card"
                wx:key="number"
                data-number="{{card.number}}"
                bindtap="onOfflineCardSelect"
              >
                <text class="md-card-num-text">{{card.number}}</text>
              </view>
            </view>
          </scroll-view>
          <text class="mof-no-card" wx:else>暂无可用的号码牌</text>
        </view>

        <!-- 确认按钮 -->
        <view class="mof-submit-wrap">
          <button class="mof-submit" bindtap="onOfflineSubmit" loading="{{offlineSubmitting}}" disabled="{{!offlineSelectedCard || offlineSubmitting}}">
            {{offlineSelectedCard ? '确认打单（绑定' + offlineSelectedCard + '号牌）' : '请选择号码牌'}}
          </button>
        </view>

        <!-- 计算器弹窗 -->
        <view class="calc-overlay" wx:if="{{showCalculator}}" catchtap="onCloseCalculator">
          <view class="calc-modal" catchtap="onPreventClose">
            <view class="calc-screen">
              <text class="calc-expr">{{calcExpression || ' '}}</text>
              <view class="calc-display-row">
                <text class="calc-currency">¥</text>
                <text class="calc-display">{{calcDisplay}}</text>
              </view>
            </view>
            <view class="calc-keyboard">
              <view class="calc-row">
                <view class="calc-key calc-key-func" data-key="C" bindtap="onCalcKey">C</view>
                <view class="calc-key calc-key-func" data-key="⌫" bindtap="onCalcKey">⌫</view>
                <view class="calc-key calc-key-op" data-key="÷" bindtap="onCalcKey">÷</view>
              </view>
              <view class="calc-row">
                <view class="calc-key" data-key="7" bindtap="onCalcKey">7</view>
                <view class="calc-key" data-key="8" bindtap="onCalcKey">8</view>
                <view class="calc-key" data-key="9" bindtap="onCalcKey">9</view>
                <view class="calc-key calc-key-op" data-key="×" bindtap="onCalcKey">×</view>
              </view>
              <view class="calc-row">
                <view class="calc-key" data-key="4" bindtap="onCalcKey">4</view>
                <view class="calc-key" data-key="5" bindtap="onCalcKey">5</view>
                <view class="calc-key" data-key="6" bindtap="onCalcKey">6</view>
                <view class="calc-key calc-key-op" data-key="-" bindtap="onCalcKey">-</view>
              </view>
              <view class="calc-row">
                <view class="calc-key" data-key="1" bindtap="onCalcKey">1</view>
                <view class="calc-key" data-key="2" bindtap="onCalcKey">2</view>
                <view class="calc-key" data-key="3" bindtap="onCalcKey">3</view>
                <view class="calc-key calc-key-op" data-key="+" bindtap="onCalcKey">+</view>
              </view>
              <view class="calc-row">
                <view class="calc-key" data-key="0" bindtap="onCalcKey">0</view>
                <view class="calc-key" data-key="." bindtap="onCalcKey">.</view>
                <view class="calc-key calc-key-eq" data-key="=" bindtap="onCalcKey">=</view>
                <view class="calc-key calc-key-confirm" data-key="✓" bindtap="onCalcConfirm">确认</view>
              </view>
            </view>
          </view>
        </view>
        <view style="height: 140rpx;"></view>
      </view>
    </scroll-view>

    <!-- ===== Tab 1/2/3：订单列表 ===== -->
    <block wx:if="{{offlineTabIndex !== 0}}">
      <scroll-view class="mo-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="mo-body" wx:if="{{offlineOrders.length > 0}}">
          <view
            class="mo-card mo-card-offline"
            wx:for="{{offlineOrders}}"
            wx:key="_id"
            data-order-no="{{item.orderNo}}"
            bindtap="onOrderTap"
          >
            <view class="mo-head">
              <view class="mo-head-left">
                <text class="mo-no">{{item.orderNo}}</text>
                <text class="mo-type-tag mo-tag-offline">线下</text>
                <text class="mo-type-tag" wx:if="{{item.paymentType === 'cash'}}">现金/扫码</text>
                <text class="mo-type-tag mo-tag-wechat" wx:elif="{{item.paymentType === 'wechat'}}">微信</text>
                <text class="mo-type-tag" wx:else>未支付</text>
              </view>
              <text class="mo-status mo-status-ok">{{item.statusText}}</text>
            </view>

            <view class="mo-items">
              <view class="mo-item" wx:if="{{item.cardNumber}}">
                <text class="mo-pname">号码牌</text>
                <text class="mo-pspec">#{{item.cardNumber}}</text>
              </view>
              <view class="mo-item">
                <text class="mo-pname">收款时间</text>
                <text class="mo-pspec">{{item.createTime}}</text>
              </view>
            </view>

            <view class="mo-foot">
              <text class="mo-amount">¥{{item.prepayDisplay}}</text>
              <view class="mo-actions">
                <button class="mo-btn mo-btn-cancel" wx:if="{{item.canCancel}}" data-order-no="{{item.orderNo}}" data-action="cancel" catchtap="onAction">取消订单</button>
                <button class="mo-btn mo-btn-process" wx:if="{{item.canProcess}}" data-order-no="{{item.orderNo}}" data-action="process" catchtap="onAction">开始处理</button>
                <button class="mo-btn mo-btn-process" wx:if="{{item.canReady}}" data-order-no="{{item.orderNo}}" data-action="ready" catchtap="onAction">处理完成</button>
                <button class="mo-btn mo-btn-pay" wx:if="{{item.canMarkPaid}}" data-order-no="{{item.orderNo}}" data-action="markPaid" catchtap="onAction">已完成支付</button>
                <button class="mo-btn mo-btn-done" wx:if="{{item.canComplete}}" data-order-no="{{item.orderNo}}" data-action="complete" catchtap="onAction">确认完成</button>
                <text class="mo-done-tag" wx:if="{{!item.canComplete && !item.canCancel && !item.canMarkPaid}}">已完成</text>
              </view>
            </view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{offlineOrders.length === 0 && !loadingOff}}">
          <text class="empty-icon">💰</text>
          <text>暂无订单</text>
        </view>
        <view class="load-more" wx:if="{{loadingOff}}">加载中...</view>
        <view style="height: 160rpx;"></view>
      </scroll-view>

    </block>
  </block>

  <!-- 打印机选择面板 -->
  <view class="md-overlay" wx:if="{{showPrinterPanel}}" catchtap="onClosePrinterPanel">
    <view class="md-modal" catchtap="onPreventClose">
      <text class="md-modal-title">选择蓝牙打印机</text>

      <view wx:if="{{printerSearching}}" style="text-align:center;padding:40rpx 0;">
        <text style="font-size:28rpx;color:#999;">正在搜索附近的蓝牙打印机...</text>
      </view>

      <view wx:if="{{printerConnecting}}" style="text-align:center;padding:20rpx;">
        <text style="font-size:28rpx;color:#FF9500;">正在连接 {{currentPrinter.name}}...</text>
      </view>

      <view wx:if="{{printing}}" style="text-align:center;padding:20rpx;">
        <text style="font-size:28rpx;color:#34C759;">正在打印小票...</text>
      </view>

      <scroll-view scroll-y style="max-height:500rpx;" wx:if="{{!printerSearching && !printerConnecting && !printing}}">
        <view wx:if="{{printers.length === 0}}" style="text-align:center;padding:40rpx 0;">
          <text style="font-size:28rpx;color:#999;">未发现蓝牙打印机</text>
          <view style="margin-top:20rpx;">
            <button bindtap="onSearchPrinters" size="mini" type="primary">🔄 重新搜索</button>
          </view>
        </view>
        <view
          wx:for="{{printers}}"
          wx:key="deviceId"
          class="printer-item"
          data-device-id="{{item.deviceId}}"
          data-device-name="{{item.name}}"
          bindtap="onSelectPrinter"
        >
          <view class="printer-item-left">
            <text class="printer-name">{{item.name}}</text>
            <text class="printer-rssi">信号: {{item.RSSI}}dBm</text>
          </view>
          <text class="printer-arrow">›</text>
        </view>
      </scroll-view>

      <view class="md-modal-btns" wx:if="{{!printerSearching && !printerConnecting && !printing}}">
        <button class="md-modal-cancel" bindtap="onClosePrinterPanel">取消</button>
        <button class="md-modal-confirm" bindtap="onSearchPrinters">🔄 重新搜索</button>
      </view>
    </view>
  </view>

  <!-- 小票预览弹窗（模拟打印） -->
  <view class="md-overlay" wx:if="{{showTicketPreview}}" catchtap="onClosePreview">
    <view class="md-modal ticket-preview-modal" catchtap="onPreventClose">
      <text class="md-modal-title">🧾 小票预览</text>

      <view class="ticket-paper">
        <view class="ticket-center">
          <text class="ticket-shop">小鲜鸡</text>
          <text class="ticket-sub">鲜鸡现宰 新鲜直达</text>
          <text class="ticket-divider">────────────────</text>
        </view>

        <view class="ticket-row">
          <text class="ticket-label">订单号：</text>
          <text>{{ticketData.orderNo}}</text>
        </view>
        <view class="ticket-row">
          <text class="ticket-label">号码牌：</text>
          <text class="ticket-card-no">{{ticketData.cardNumber}}</text>
        </view>
        <view class="ticket-row" wx:if="{{ticketData.paymentLabel}}">
          <text class="ticket-label">支付方式：</text>
          <text>{{ticketData.paymentLabel}}</text>
        </view>
        <view class="ticket-center ticket-amount-block">
          <text class="ticket-amount">¥{{ticketData.amountYuan}}</text>
        </view>

        <text class="ticket-divider">────────────────</text>

        <view class="ticket-center">
          <image wx:if="{{ticketQrUrl}}" class="ticket-qr" src="{{ticketQrUrl}}" mode="aspectFit" />
          <text wx:else class="ticket-qr-placeholder">[QR码加载中...]</text>
          <text class="ticket-qr-hint">扫码查看取货进度</text>
        </view>

        <text class="ticket-divider">────────────────</text>

        <view class="ticket-center">
          <text class="ticket-time">{{ticketData.time}}</text>
          <text class="ticket-thanks">谢谢惠顾，欢迎再次光临</text>
        </view>
      </view>

      <view class="md-modal-btns">
        <button class="md-modal-cancel" bindtap="onClosePreview">关闭</button>
        <button class="md-modal-confirm" bindtap="onMockPrintDone">✓ 确认打印</button>
      </view>
    </view>
  </view>

  <!-- Custom TabBar -->
  <custom-tab-bar current="orders" theme="merchant" bind:change="onTabChange" />
</view>
