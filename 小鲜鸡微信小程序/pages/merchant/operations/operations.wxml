<view class="op-page">
  <scroll-view class="op-scroll" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- Date range -->
    <view class="op-date-bar">
      <view class="op-date" bindtap="onPrevDay">‹</view>
      <text class="op-date-text">{{dateLabel}}</text>
      <view class="op-date" bindtap="onNextDay">›</view>
    </view>

    <!-- Loading -->
    <view class="op-loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <!-- Revenue overview -->
    <view class="op-overview" wx:if="{{!loading}}">
      <view class="op-ov-card">
        <text class="op-ov-value">¥{{todayRevenue}}</text>
        <text class="op-ov-label">当日营收</text>
      </view>
      <view class="op-ov-card">
        <text class="op-ov-value">{{todayOrders}}</text>
        <text class="op-ov-label">总订单</text>
      </view>
      <view class="op-ov-card">
        <text class="op-ov-value">{{avgOrderValue}}</text>
        <text class="op-ov-label">客单价</text>
      </view>
    </view>

    <!-- Order breakdown -->
    <view class="op-breakdown" wx:if="{{!loading}}">
      <text class="op-bd-text">线上 {{todayOnlineOrders}} 单 · 线下 {{todayOfflineOrders}} 单</text>
    </view>

    <!-- Sales ranking -->
    <view class="card-full">
      <text class="op-sec-title">商品销量排行 TOP10</text>
      <view wx:if="{{salesRank.length > 0}}">
        <view class="op-rank-item" wx:for="{{salesRank}}" wx:key="productId">
          <view class="op-rank-num {{index < 3 ? 'op-rank-top' + (index + 1) : ''}}">{{index + 1}}</view>
          <view class="op-rank-info">
            <text class="op-rank-name">{{item.productName}}</text>
            <view class="op-rank-bar-wrap">
              <view class="op-rank-bar" style="width: {{item.percent}}%;"></view>
            </view>
          </view>
          <text class="op-rank-sales">{{item.count}}单</text>
        </view>
      </view>
      <view class="op-empty" wx:else>
        <text>暂无销售数据</text>
      </view>
    </view>

    <!-- Category breakdown -->
    <view class="card-full">
      <text class="op-sec-title">各品类销量占比</text>
      <view wx:if="{{categoryStats.length > 0}}">
        <view class="op-cat-item" wx:for="{{categoryStats}}" wx:key="name">
          <view class="op-cat-head">
            <text class="op-cat-name">{{item.name}}</text>
            <text class="op-cat-pct">{{item.percent}}%</text>
          </view>
          <view class="op-cat-bar-wrap">
            <view class="op-cat-bar" style="width: {{item.percent}}%; background: {{item.color}};"></view>
          </view>
        </view>
      </view>
      <view class="op-empty" wx:else>
        <text>暂无数据</text>
      </view>
    </view>

    <!-- Recent orders -->
    <view class="card-full">
      <text class="op-sec-title">最近订单</text>
      <view wx:if="{{recentOrders.length > 0}}">
        <view class="op-order-item" wx:for="{{recentOrders}}" wx:key="orderNo">
          <view class="op-order-left">
            <text class="op-order-no">{{item.orderNo}}</text>
            <text class="op-order-type">{{item.typeLabel}}</text>
          </view>
          <view class="op-order-right">
            <text class="op-order-amount">¥{{item.amountDisplay}}</text>
            <text class="op-order-status {{item.status === 'completed' ? 'op-status-done' : ''}}">{{item.statusText}}</text>
          </view>
        </view>
      </view>
      <view class="op-empty" wx:else>
        <text>暂无订单</text>
      </view>
    </view>

    <view style="height: 140rpx;"></view>
  </scroll-view>

  <custom-tab-bar current="operations" theme="merchant" bind:change="onTabChange" />
</view>
