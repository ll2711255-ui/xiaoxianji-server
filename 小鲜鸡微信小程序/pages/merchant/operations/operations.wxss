.op-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.op-scroll {
  flex: 1;
  height: 0;
}

/* Date bar */
.op-date-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
  padding: 20rpx 0 28rpx;
  gap: 32rpx;
}
.op-date {
  width: 52rpx;
  height: 52rpx;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.12);
  color: #fff;
  font-size: var(--font-lg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.op-date-text {
  font-size: var(--font-lg);
  font-weight: 600;
  color: #fff;
  min-width: 200rpx;
  text-align: center;
}

/* Overview */
.op-overview {
  display: flex;
  padding: 0 24rpx;
  margin-top: -16rpx;
  gap: 12rpx;
}
.op-ov-card {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.op-ov-value {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--color-text-1);
  display: block;
}
.op-ov-label {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  margin-top: 6rpx;
  display: block;
}

/* Section */
.op-sec-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-1);
  display: block;
  margin-bottom: 20rpx;
}

/* Sales rank */
.op-rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
}
.op-rank-item + .op-rank-item {
  border-top: 1rpx solid var(--color-border);
}
.op-rank-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
  color: var(--color-text-3);
  font-size: var(--font-md);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.op-rank-top1 { background: var(--color-primary); color: #fff; }
.op-rank-top2 { background: var(--color-warning); color: #fff; }
.op-rank-top3 { background: var(--color-brand-yolk); color: #fff; }

.op-rank-info {
  flex: 1;
  min-width: 0;
}
.op-rank-name {
  font-size: var(--font-base);
  color: var(--color-text-1);
  display: block;
  margin-bottom: 6rpx;
}
.op-rank-bar-wrap {
  height: 8rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.op-rank-bar {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-sm);
  transition: width 0.5s;
}
.op-rank-sales {
  font-size: var(--font-md);
  color: var(--color-text-3);
  flex-shrink: 0;
}

/* Category */
.op-cat-item {
  padding: 14rpx 0;
}
.op-cat-item + .op-cat-item {
  border-top: 1rpx solid var(--color-border);
}
.op-cat-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.op-cat-name {
  font-size: var(--font-base);
  color: var(--color-text-1);
}
.op-cat-pct {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
}
.op-cat-bar-wrap {
  height: 12rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.op-cat-bar {
  height: 100%;
  border-radius: var(--radius-sm);
  transition: width 0.5s;
}

/* Recent orders */
.op-order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}
.op-order-item + .op-order-item {
  border-top: 1rpx solid var(--color-border);
}
.op-order-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.op-order-no {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-1);
}
.op-order-type {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}
.op-order-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}
.op-order-amount {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
}
.op-order-status {
  font-size: var(--font-sm);
  color: var(--color-warning);
}
.op-status-done {
  color: var(--color-primary);
}

.op-empty {
  text-align: center;
  padding: 48rpx 0;
  color: var(--color-text-3);
  font-size: var(--font-base);
}
