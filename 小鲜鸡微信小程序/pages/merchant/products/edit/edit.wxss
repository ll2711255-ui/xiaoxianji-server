.pe-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.pe-body {
  padding-bottom: 140rpx;
}

.pe-section {
  background: var(--color-bg-card);
  margin: 16rpx 24rpx;
  border-radius: var(--radius-md);
  padding: 24rpx;
}

.pe-sec-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-1);
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.pe-hint {
  font-size: var(--font-md);
  color: var(--color-warning);
  padding: 16rpx 0;
}

/* Row */
.pe-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  gap: 16rpx;
}
.pe-label {
  font-size: var(--font-base);
  color: var(--color-text-2);
  width: 170rpx;
  flex-shrink: 0;
}
.pe-input {
  flex: 1;
  font-size: var(--font-base);
  text-align: right;
  color: var(--color-text-1);
}
.pe-textarea {
  flex: 1;
  font-size: var(--font-base);
  height: 120rpx;
  text-align: right;
  color: var(--color-text-1);
}
.pe-picker {
  flex: 1;
  font-size: var(--font-base);
  text-align: right;
  color: var(--color-text-1);
}
.pe-value {
  flex: 1;
  font-size: var(--font-base);
  text-align: right;
  color: var(--color-text-3);
}

/* Checkbox row */
.pe-check-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 0;
  font-size: var(--font-base);
  color: var(--color-text-1);
}

/* Images */
.pe-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.pe-img-item {
  width: 150rpx;
  height: 150rpx;
  border-radius: var(--radius-md);
  position: relative;
  overflow: hidden;
}
.pe-img {
  width: 100%;
  height: 100%;
}
.pe-img-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: var(--font-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 8rpx 0 8rpx;
}
.pe-img-add {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.pe-img-add-icon {
  font-size: 52rpx;
  color: var(--color-text-3);
}
.pe-img-add-text {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}

/* Category row with add button */
.pe-cat-row {
  flex-wrap: wrap;
}
.pe-cat-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}
.pe-cat-picker {
  flex: 1;
}
.pe-cat-add-btn {
  font-size: var(--font-md);
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-lg);
  white-space: nowrap;
  flex-shrink: 0;
}
.pe-cat-add-btn:active {
  background: var(--color-warning-bg);
}
.pe-cat-del-btn {
  font-size: var(--font-md);
  color: var(--color-danger);
  padding: 6rpx 16rpx;
  border: 1px solid var(--color-danger);
  border-radius: var(--radius-lg);
  white-space: nowrap;
  flex-shrink: 0;
}
.pe-cat-del-btn:active {
  background: var(--color-primary-pale);
}

/* Inline add category */
.pe-add-cat {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  margin: 0 24rpx;
  background: var(--color-primary-pale);
  border-radius: var(--radius-md);
  margin-bottom: 4rpx;
}
.pe-add-cat-input {
  flex: 1;
  font-size: var(--font-base);
  height: 60rpx;
  padding: 0 16rpx;
  background: var(--color-bg-card);
  border: 1px solid var(--color-danger-bg);
  border-radius: var(--radius-md);
}
.pe-add-cat-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}
.pe-add-cat-cancel {
  font-size: var(--font-md);
  color: var(--color-text-3);
  padding: 10rpx 16rpx;
}
.pe-add-cat-confirm {
  font-size: var(--font-md);
  color: #fff;
  background: var(--color-primary);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-lg);
}
.pe-add-cat-confirm:active {
  background: var(--color-primary);
}

/* Type card (range_weight — 每个称重类型卡片) */
.pe-type-card {
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 20rpx;
  margin-bottom: 24rpx;
}
.pe-type-card-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--color-border);
}
.pe-type-card-label {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-1);
}

/* Specs editor (range_weight) */
.pe-spec-block {
  margin-top: 16rpx;
}
.pe-type-card .pe-spec-block {
  margin-bottom: 0;
}
.pe-type-card .pe-spec-block-hd {
  margin-top: 8rpx;
}
.pe-spec-block-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.pe-sub-title {
  font-size: var(--font-md);
  color: var(--color-text-3);
  font-weight: 500;
}
.pe-spec-count {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}
.pe-spec-item {
  margin-bottom: 8rpx;
}
.pe-spec-item-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 10rpx 12rpx;
}
.pe-spec-input {
  font-size: var(--font-md);
  height: 56rpx;
  padding: 0 12rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  color: var(--color-text-1);
}
.pe-spec-flex2 {
  flex: 2;
}
.pe-spec-flex1 {
  flex: 1;
}
.pe-spec-del {
  font-size: var(--font-base);
  color: var(--color-text-3);
  padding: 8rpx;
  flex-shrink: 0;
}
.pe-spec-del:active {
  color: var(--color-primary);
}
/* 重量选项斤数提示 */
.pe-weight-jin-hint {
  font-size: var(--font-sm);
  color: var(--color-primary);
  flex-shrink: 0;
  min-width: 72rpx;
  text-align: center;
  font-weight: 500;
}
.pe-weight-jin-empty {
  color: var(--color-text-3);
  font-weight: 400;
}
.pe-spec-add {
  font-size: var(--font-md);
  color: var(--color-primary);
  padding: 12rpx 0;
  text-align: center;
  border: 1rpx dashed var(--color-danger-bg);
  border-radius: var(--radius-md);
  margin-top: 8rpx;
}
.pe-spec-add:active {
  background: var(--color-warning-bg);
}
.pe-spec-preview {
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--color-primary-pale);
  border-radius: var(--radius-md);
}
.pe-preview-text {
  font-size: var(--font-md);
  color: var(--color-primary);
  text-align: center;
  display: block;
}

/* Processing option chips */
.pe-proc-row {
  flex-wrap: wrap;
  align-items: flex-start;
}
.pe-proc-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}
.pe-proc-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-end;
}
.pe-proc-chip {
  font-size: var(--font-md);
  color: var(--color-text-2);
  background: var(--color-bg-page);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 8rpx 24rpx;
  transition: all 0.15s;
}
.pe-proc-chip.on {
  color: var(--color-primary);
  background: var(--color-primary-pale);
  border-color: var(--color-primary-light);
  font-weight: 500;
}
.pe-proc-chip:active {
  opacity: 0.7;
}
.pe-proc-add-btn {
  font-size: var(--font-sm);
  color: var(--color-primary);
  padding: 6rpx 16rpx;
  border: 1px dashed var(--color-primary-light);
  border-radius: var(--radius-lg);
}
.pe-proc-add-btn:active {
  background: var(--color-warning-bg);
}
.pe-proc-add-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 100%;
}
.pe-proc-add-input {
  flex: 1;
  font-size: var(--font-md);
  height: 54rpx;
  padding: 0 14rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-danger-bg);
  border-radius: var(--radius-md);
}
.pe-proc-add-cancel {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  padding: 8rpx 12rpx;
  flex-shrink: 0;
}
.pe-proc-add-confirm {
  font-size: var(--font-sm);
  color: #fff;
  background: var(--color-primary);
  padding: 8rpx 18rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}
.pe-proc-add-confirm:active {
  background: var(--color-primary);
}

/* Bottom bar */
.pe-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.06);
}
.pe-btn-cancel {
  flex: 1;
  background: var(--color-bg-page);
  color: var(--color-text-3);
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  border: none;
  padding: 20rpx 0;
}
.pe-btn-save {
  flex: 2;
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: 600;
  border: none;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}
