.mp-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

/* ========== 顶部标题栏 ========== */
.mp-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
}
.mp-topbar-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: #fff;
}
.mp-topbar-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.mp-topbar-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  color: #fff;
}
.mp-topbar-btn.on {
  background: rgba(255,255,255,0.45);
}
.mp-topbar-add-icon {
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
}

/* ========== 主体：左右分栏 ========== */
.mp-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* ========== 左侧分类导航（160rpx） ========== */
.mp-sidebar {
  width: 160rpx;
  background: var(--color-bg-card);
  border-right: 1rpx solid var(--color-border);
  flex-shrink: 0;
}
.mp-side-item {
  padding: 24rpx 8rpx;
  text-align: center;
  font-size: var(--font-md);
  color: var(--color-text-2);
  border-left: 6rpx solid transparent;
  position: relative;
}
.mp-side-item.active {
  color: var(--color-primary);
  font-weight: 600;
  background: var(--color-primary-pale);
  border-left-color: var(--color-primary);
}

/* 排序模式 */
.mp-side-sort-hint {
  display: block;
  text-align: center;
  font-size: var(--font-sm);
  color: var(--color-text-3);
  padding: 16rpx 8rpx;
  background: var(--color-bg-page);
  border-bottom: 1rpx solid var(--color-border);
}
.mp-side-item-sort {
  padding: 18rpx 6rpx;
}
.mp-side-item-top { border-top: 2rpx solid var(--color-primary); }
.mp-side-item-bottom { border-bottom: 2rpx solid var(--color-primary); }
.mp-side-sort-arrows {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.mp-side-sort-arrow {
  font-size: var(--font-xs);
  color: var(--color-primary);
  padding: 4rpx 8rpx;
}
.mp-side-sort-name {
  font-size: var(--font-sm);
  color: var(--color-text-1);
  font-weight: 500;
}
.mp-side-sort-btns {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 8rpx;
  text-align: center;
}
.mp-side-sort-save {
  font-size: var(--font-md);
  color: #fff;
  background: var(--color-primary);
  border-radius: var(--radius-md);
  padding: 10rpx 0;
  display: block;
  text-align: center;
}
.mp-side-sort-cancel {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  padding: 6rpx 0;
  display: block;
  text-align: center;
}

/* 侧边栏底部提示 */
.mp-side-hint {
  text-align: center;
  font-size: var(--font-xs);
  color: var(--color-text-3);
  padding: 12rpx 8rpx;
  border-top: 1rpx solid var(--color-border);
}

/* ========== 右侧内容区（flex 1） ========== */
.mp-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 搜索框 */
.mp-content-search {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background: var(--color-bg-card);
  gap: 12rpx;
}
.mp-content-search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-bg-page);
  border-radius: var(--radius-xl);
  padding: 8rpx 20rpx;
  gap: 8rpx;
}
.mp-content-search-icon {
  font-size: var(--font-base);
  flex-shrink: 0;
}
.mp-content-search-input {
  flex: 1;
  font-size: var(--font-md);
  color: var(--color-text-1);
  height: 52rpx;
  line-height: 52rpx;
}
.mp-content-search-ph {
  color: var(--color-text-3);
  font-size: var(--font-md);
}
.mp-content-search-clr {
  font-size: var(--font-md);
  color: var(--color-text-3);
  padding: 4rpx 8rpx;
  flex-shrink: 0;
}
.mp-content-search-cancel {
  color: var(--color-primary);
  font-size: var(--font-md);
  padding: 8rpx 0 8rpx 4rpx;
  flex-shrink: 0;
  white-space: nowrap;
}
.mp-content-hint {
  padding: 14rpx 20rpx;
  font-size: var(--font-sm);
  color: var(--color-text-3);
  background: var(--color-bg-page);
}
.mp-content-sort-hint {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

/* 滚动区域 */
.mp-scroll {
  flex: 1;
  height: 0;
}

/* 商品列表 */
.mp-list {
  padding: 16rpx 16rpx;
}

/* 商品卡片 */
.mp-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.mp-card.mp-off {
  opacity: 0.65;
}

.mp-card-main {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.mp-img-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}
.mp-img {
  width: 100%;
  height: 100%;
}
.mp-img-empty {
  font-size: 60rpx;
}

.mp-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}
.mp-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mp-desc {
  font-size: var(--font-md);
  color: var(--color-text-3);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mp-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.mp-price {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
}
.mp-unit {
  font-size: var(--font-sm);
  font-weight: 400;
  color: var(--color-text-3);
  margin-left: 2rpx;
}
.mp-sales {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}

/* 卡片底部操作 */
.mp-card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 20rpx;
  border-top: 1rpx solid var(--color-border);
  background: var(--color-bg-page);
}
.mp-status-tag {
  font-size: var(--font-sm);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
}
.mp-on {
  background: var(--color-primary-pale);
  color: var(--color-primary);
}
.mp-off-tag {
  background: var(--color-bg-page);
  color: var(--color-text-3);
}
.mp-out {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

/* 开关组 */
.mp-switches {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.mp-switch-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.mp-switch-label {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}
.mp-switch-disabled .mp-switch-label {
  color: #E0E0E0;
}

/* ========== 通用空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  color: var(--color-text-3);
  font-size: var(--font-base);
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.empty-hint {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  margin-top: 8rpx;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  color: var(--color-text-3);
  font-size: var(--font-md);
}

/* ========== 广告管理模式 ========== */
.mp-banner-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}
.mp-banner-topbar-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-1);
}
.mp-banner-topbar-save {
  font-size: var(--font-base);
  font-weight: 600;
  color: #fff;
  background: var(--color-primary);
  padding: 10rpx 28rpx;
  border-radius: var(--radius-xl);
}

.mp-banner-list {
  padding: 16rpx;
}

.mp-banner-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.04);
}
.mp-banner-card.editing {
  border: 2rpx solid var(--color-primary);
}
.mp-banner-off {
  opacity: 0.6;
}

.mp-banner-main {
  display: flex;
  align-items: center;
  padding: 16rpx;
  gap: 16rpx;
}
.mp-banner-img-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}
.mp-banner-img {
  width: 100%;
  height: 100%;
}
.mp-banner-img-empty {
  font-size: 48rpx;
  color: var(--color-text-3);
}
.mp-banner-info {
  flex: 1;
  min-width: 0;
}
.mp-banner-title-text {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--color-text-1);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mp-banner-sub-text {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mp-banner-del {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-pale);
  color: var(--color-danger);
  font-size: var(--font-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 广告编辑区 */
.mp-banner-edit {
  padding: 0 16rpx 16rpx;
  border-top: 1rpx solid var(--color-border);
}
.mp-banner-edit-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
}
.mp-banner-edit-label {
  font-size: var(--font-sm);
  color: var(--color-text-2);
  flex-shrink: 0;
  width: 110rpx;
}
.mp-banner-edit-input {
  flex: 1;
  height: 56rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 16rpx;
  font-size: var(--font-md);
  color: var(--color-text-1);
}
.mp-banner-color-input {
  max-width: 200rpx;
}
.mp-banner-color-preview {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  flex-shrink: 0;
}
.mp-banner-edit-actions {
  justify-content: space-between;
}
.mp-banner-edit-left,
.mp-banner-edit-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.mp-banner-switch-label {
  font-size: var(--font-sm);
  color: var(--color-text-2);
}
.mp-banner-move-btn {
  font-size: var(--font-md);
  color: var(--color-primary);
  padding: 6rpx 12rpx;
}
.mp-banner-move-disabled {
  color: var(--color-text-3);
}
.mp-banner-add-row {
  padding: 16rpx;
  text-align: center;
}
.mp-banner-add-btn {
  display: inline-block;
  padding: 14rpx 48rpx;
  border-radius: var(--radius-xl);
  border: 2rpx dashed var(--color-primary);
  color: var(--color-primary);
  font-size: var(--font-md);
  font-weight: 600;
}
.mp-banner-limit-hint {
  text-align: center;
  padding: 16rpx;
  font-size: var(--font-sm);
  color: var(--color-text-3);
}
