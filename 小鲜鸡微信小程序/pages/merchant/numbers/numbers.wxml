<view class="mn-page">
  <view class="mn-header">
    <text class="mn-title">号码牌状态</text>
    <view class="mn-legend">
      <view class="mn-legend-item"><view class="mn-dot idle"></view><text>空闲</text></view>
      <view class="mn-legend-item"><view class="mn-dot used"></view><text>使用中</text></view>
    </view>
  </view>

  <view class="mn-grid" wx:if="{{!loading}}">
    <view
      class="mn-card {{card.status === 'idle' ? 'idle' : 'used'}}"
      wx:for="{{numbers}}"
      wx:key="number"
      data-number="{{card.number}}"
      bindtap="onCardTap"
      bindlongpress="onCardTap"
    >
      <text class="mn-num">{{card.number}}</text>
    </view>
  </view>

  <view class="mn-refresh" bindtap="onRefresh">
    <text>刷新状态</text>
  </view>

  <view class="empty-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>