/* 商家首页 */
.md-root {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.md-header {
  background: linear-gradient(135deg, var(--color-brand-dark-red), var(--color-brand-main-red));
  padding: 56rpx 32rpx 40rpx;
}

.md-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.md-sub {
  font-size: var(--font-base);
  color: rgba(255,255,255,0.6);
  margin-top: 8rpx;
  display: block;
}

/* 统计 */
.md-stats {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  margin-top: -20rpx;
}

.md-stat-card {
  flex: 1;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.md-stat-num {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--color-primary);
  display: block;
}

.md-stat-active .md-stat-num {
  color: var(--color-primary);
}

.md-stat-label {
  font-size: var(--font-md);
  color: var(--color-text-3);
  margin-top: 8rpx;
  display: block;
}

/* 菜单 */
.md-menu {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin: 0 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.md-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
}

.md-item + .md-item {
  border-top: 1rpx solid var(--color-border);
}

.md-item:active {
  background: var(--color-bg-page);
}

.md-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.md-item-icon {
  font-size: var(--font-xl);
}

.md-item-text {
  font-size: var(--font-lg);
  color: var(--color-text-1);
}

.md-arrow {
  font-size: var(--font-xl);
  color: var(--color-text-3);
}

/* 退出 */
.md-logout-wrap {
  padding: 40rpx 24rpx;
}

.md-logout {
  width: 100%;
  background: var(--color-bg-card);
  color: var(--color-danger);
  border: 1rpx solid var(--color-danger);
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  padding: 20rpx 0;
}
