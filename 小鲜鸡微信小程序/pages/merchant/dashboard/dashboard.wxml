<view class="md-root">
  <!-- 顶部 -->
  <view class="md-header">
    <text class="md-title">商家管理后台</text>
    <text class="md-sub">小鲜鸡</text>
  </view>

  <!-- 统计卡片 -->
  <view class="md-stats">
    <view class="md-stat-card" bindtap="onGoOrders">
      <text class="md-stat-num">{{pendingCount}}</text>
      <text class="md-stat-label">待接单</text>
    </view>
    <view class="md-stat-card md-stat-active" bindtap="onGoOrders">
      <text class="md-stat-num">{{activeCount}}</text>
      <text class="md-stat-label">进行中</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="md-menu">
    <view class="md-item" bindtap="onGoOrders">
      <view class="md-item-left">
        <text class="md-item-icon">📋</text>
        <text class="md-item-text">订单管理</text>
      </view>
      <text class="md-arrow">›</text>
    </view>
    <view class="md-item" bindtap="onGoNumbers">
      <view class="md-item-left">
        <text class="md-item-icon">🔢</text>
        <text class="md-item-text">号码牌管理</text>
      </view>
      <text class="md-arrow">›</text>
    </view>
    <view class="md-item" bindtap="onGoOffline">
      <view class="md-item-left">
        <text class="md-item-icon">💵</text>
        <text class="md-item-text">线下收银</text>
      </view>
      <text class="md-arrow">›</text>
    </view>
  </view>

  <!-- 退出 -->
  <view class="md-logout-wrap">
    <button class="md-logout" bindtap="onLogout">退出商家模式</button>
  </view>
</view>
