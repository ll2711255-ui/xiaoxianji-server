/* ========== 商品详情页 ========== */

/* ========== 商品图片区 ========== */
.detail-img-area {
  width: 100%;
  height: 420rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-img {
  width: 100%;
  height: 100%;
}

.detail-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background: #f0faf5;
}

.detail-emoji {
  font-size: 188rpx;
}

/* ========== 价格信息卡片 ========== */
.price-card {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx 24rpx 24rpx;
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
}

.price-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-left {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 32rpx;
  color: #FF4B26;
  font-weight: 700;
}

.price-value {
  font-size: 52rpx;
  color: #FF4B26;
  font-weight: 700;
  line-height: 1;
}

.price-label {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

.price-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  display: block;
  margin-top: 14rpx;
}

.price-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
}

.price-sales {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-top: 12rpx;
}

/* ========== 规格选择卡片 ========== */
.spec-card {
  background: #fff;
  margin: 16rpx 0 0;
  padding: 24rpx;
}

.spec-section {
  margin-bottom: 32rpx;
}

.spec-section:last-child {
  margin-bottom: 0;
}

.spec-label {
  font-size: 30rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 规格胶囊按钮 */
.spec-btn {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #555;
  background: #fff;
  border: 1px solid #ddd;
}

.spec-btn.active {
  color: #1DB96A;
  border-color: #1DB96A;
  background: #f0faf5;
}

/* ========== 数量步进器 ========== */
.qty-stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #333;
  font-weight: 500;
  border: 1px solid #ddd;
}

.stepper-btn:active {
  background: #E5E5E5;
}

.stepper-plus {
  background: linear-gradient(135deg, var(--color-brand-main-red), var(--color-brand-tangerine));
  color: #fff;
  border-color: var(--color-brand-main-red);
}

.stepper-plus:active {
  opacity: 0.85;
}

.stepper-disabled {
  opacity: 0.4;
}

.stepper-val {
  font-size: 38rpx;
  font-weight: 700;
  min-width: 56rpx;
  text-align: center;
}

/* ========== 计价说明卡片 ========== */
.pricing-note-card {
  margin: 16rpx 0 0;
  padding: 24rpx;
  background: #F5F5F5;
}

.pricing-note-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #666;
  display: block;
}

.pricing-note-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
  line-height: 1.6;
}

/* ========== 加载状态 ========== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  font-size: 32rpx;
  color: #C7C7CC;
}

/* ========== 底部操作栏 ========== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  gap: 20rpx;
}

.action-price-col {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.action-price-symbol {
  font-size: 28rpx;
  color: #FF4B26;
  font-weight: 700;
}

.action-price-val {
  font-size: 44rpx;
  color: #FF4B26;
  font-weight: 700;
  line-height: 1;
}

.action-btn {
  flex: 1;
  text-align: center;
  border-radius: 40rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  white-space: nowrap;
}

.action-btn:active {
  opacity: 0.85;
}

/* 加入购物车 — 描边样式 */
.action-btn-cart {
  background: #FFF4F0;
  color: #FF5722;
  border: 2rpx solid #FF5722;
  flex: 1.1;
}

/* 立即购买 — 实心渐变 */
.action-btn-buy {
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  color: #fff;
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
  flex: 1.4;
}

.action-btn-disabled {
  background: #C7C7CC;
  color: #fff;
  border-color: transparent;
  box-shadow: none;
  pointer-events: none;
}
