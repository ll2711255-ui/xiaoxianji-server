<block wx:if="{{!loading && product}}">
  <!-- ========== 商品图片区 ========== -->
  <view class="detail-img-area">
    <image
      class="detail-img"
      src="{{images[0]}}"
      mode="aspectFill"
      wx:if="{{images.length > 0}}"
      bindtap="onPreviewImage"
      data-src="{{images[0]}}"
    />
    <view class="detail-img-placeholder" wx:else>
      <text class="detail-emoji">{{categoryEmoji}}</text>
    </view>
  </view>

  <!-- ========== 价格信息卡片 ========== -->
  <view class="price-card">
    <view class="price-top-row">
      <view class="price-left">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{displayPriceStr}}</text>
        <text class="price-label">{{priceLabel}}</text>
      </view>
    </view>
    <text class="price-name">{{productName}}</text>
    <view class="price-tags">
      <text class="tag tag-green">现杀新鲜</text>
      <text class="tag tag-orange" wx:if="{{pricingType === 'range_weight'}}">称重退差价</text>
    </view>
    <text class="price-sales">已售 {{salesDisplay}} 份</text>
  </view>

  <!-- ========== 规格选择区 ========== -->

  <!-- 分支一：整鸡 range_weight — 四个规格 section -->
  <block wx:if="{{pricingType === 'range_weight'}}">
    <view class="spec-card">
      <!-- 规格一：称重类型 -->
      <view class="spec-section">
        <view class="spec-label">规格一：称重类型</view>
        <view class="spec-options">
          <view
            wx:for="{{typeOptions}}"
            wx:key="value"
            class="spec-btn {{selectedType === item.value ? 'active' : ''}}"
            bindtap="onSelectType"
            data-value="{{item.value}}"
          >
            <text>{{item.label}} ¥{{item.pricePerJinDisplay}}/斤</text>
          </view>
        </view>
      </view>

      <!-- 规格二：重量范围 -->
      <view class="spec-section">
        <view class="spec-label">规格二：重量范围 {{weightSpecLabel}}</view>
        <view class="spec-options">
          <view
            wx:for="{{weightOptions}}"
            wx:key="value"
            class="spec-btn {{selectedWeight.value === item.value ? 'active' : ''}}"
            bindtap="onSelectWeight"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 数量选择 -->
      <view class="spec-section">
        <view class="spec-label">数量选择</view>
        <view class="qty-stepper">
          <view class="stepper-btn {{quantity <= 1 ? 'stepper-disabled' : ''}}" bindtap="onQuantityMinus">
            <text>−</text>
          </view>
          <text class="stepper-val">{{quantity}}</text>
          <view class="stepper-btn stepper-plus {{quantity >= 99 ? 'stepper-disabled' : ''}}" bindtap="onQuantityPlus">
            <text>+</text>
          </view>
        </view>
      </view>

      <!-- 规格三：处理方式 -->
      <view class="spec-section" wx:if="{{processingOptions.length > 0}}">
        <view class="spec-label">规格三：处理方式</view>
        <view class="spec-options">
          <view
            wx:for="{{processingOptions}}"
            wx:key="value"
            class="spec-btn {{selectedProcessing === item.value ? 'active' : ''}}"
            bindtap="onSelectProcessing"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 备注 -->
      <view class="spec-section">
        <view class="spec-label">备注（选填）</view>
        <view class="remark-wrap">
          <input class="remark-input" placeholder="如有特殊要求请在此备注" value="{{remark}}" bindinput="onInputRemark" />
        </view>
      </view>

      <!-- 规格四：取货方式 -->
      <view class="spec-section">
        <view class="spec-label">规格四：取货方式</view>
        <view class="spec-options">
          <view
            wx:for="{{deliveryOptions}}"
            wx:key="value"
            class="spec-btn {{selectedDelivery === item.value ? 'active' : ''}}"
            bindtap="onSelectDelivery"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 计价说明（整鸡专用） -->
    <view class="pricing-note-card">
      <text class="pricing-note-title">计价说明</text>
      <text class="pricing-note-text">本商品按重量范围预收费用，实际价格以称重为准。称重后差额将原路退回您的支付账户。</text>
    </view>
  </block>

  <!-- 分支二：exact_weight（鸡腿/鸡翅等）— 三个 section -->
  <block wx:if="{{pricingType === 'exact_weight'}}">
    <view class="spec-card">
      <!-- 重量选择 -->
      <view class="spec-section">
        <view class="spec-label">重量选择</view>
        <view class="spec-options">
          <view
            wx:for="{{weightOptions}}"
            wx:key="value"
            class="spec-btn {{selectedWeight.value === item.value ? 'active' : ''}}"
            bindtap="onSelectWeight"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 数量选择 -->
      <view class="spec-section">
        <view class="spec-label">数量选择</view>
        <view class="qty-stepper">
          <view class="stepper-btn {{quantity <= 1 ? 'stepper-disabled' : ''}}" bindtap="onQuantityMinus">
            <text>−</text>
          </view>
          <text class="stepper-val">{{quantity}}</text>
          <view class="stepper-btn stepper-plus {{quantity >= 99 ? 'stepper-disabled' : ''}}" bindtap="onQuantityPlus">
            <text>+</text>
          </view>
        </view>
      </view>

      <!-- 处理方式 -->
      <view class="spec-section" wx:if="{{processingOptions.length > 0}}">
        <view class="spec-label">处理方式</view>
        <view class="spec-options">
          <view
            wx:for="{{processingOptions}}"
            wx:key="value"
            class="spec-btn {{selectedProcessing === item.value ? 'active' : ''}}"
            bindtap="onSelectProcessing"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 备注 -->
      <view class="spec-section">
        <view class="spec-label">备注（选填）</view>
        <view class="remark-wrap">
          <input class="remark-input" placeholder="如有特殊要求请在此备注" value="{{remark}}" bindinput="onInputRemark" />
        </view>
      </view>

      <!-- 取货方式 -->
      <view class="spec-section">
        <view class="spec-label">取货方式</view>
        <view class="spec-options">
          <view
            wx:for="{{deliveryOptions}}"
            wx:key="value"
            class="spec-btn {{selectedDelivery === item.value ? 'active' : ''}}"
            bindtap="onSelectDelivery"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 分支三：per_piece（鸽子）— 三个 section -->
  <block wx:if="{{pricingType === 'per_piece'}}">
    <view class="spec-card">
      <!-- 数量选择 -->
      <view class="spec-section">
        <view class="spec-label">数量选择</view>
        <view class="qty-stepper">
          <view class="stepper-btn {{quantity <= 1 ? 'stepper-disabled' : ''}}" bindtap="onQuantityMinus">
            <text>−</text>
          </view>
          <text class="stepper-val">{{quantity}}</text>
          <view class="stepper-btn stepper-plus {{quantity >= 99 ? 'stepper-disabled' : ''}}" bindtap="onQuantityPlus">
            <text>+</text>
          </view>
        </view>
      </view>

      <!-- 处理方式 -->
      <view class="spec-section" wx:if="{{processingOptions.length > 0}}">
        <view class="spec-label">处理方式</view>
        <view class="spec-options">
          <view
            wx:for="{{processingOptions}}"
            wx:key="value"
            class="spec-btn {{selectedProcessing === item.value ? 'active' : ''}}"
            bindtap="onSelectProcessing"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 备注 -->
      <view class="spec-section">
        <view class="spec-label">备注（选填）</view>
        <view class="remark-wrap">
          <input class="remark-input" placeholder="如有特殊要求请在此备注" value="{{remark}}" bindinput="onInputRemark" />
        </view>
      </view>

      <!-- 取货方式 -->
      <view class="spec-section">
        <view class="spec-label">取货方式</view>
        <view class="spec-options">
          <view
            wx:for="{{deliveryOptions}}"
            wx:key="value"
            class="spec-btn {{selectedDelivery === item.value ? 'active' : ''}}"
            bindtap="onSelectDelivery"
            data-value="{{item.value}}"
          >
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!-- 底部留白 -->
  <view style="height: 140rpx;"></view>
</block>

<!-- 加载中 -->
<view class="loading-wrap" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<!-- ========== 底部操作栏 ========== -->
<view class="action-bar" wx:if="{{!loading && product}}">
  <view class="action-price-col">
    <text class="action-price-symbol">¥</text>
    <text class="action-price-val">{{displayPriceStr}}</text>
  </view>
  <view class="action-btn action-btn-cart {{product.out_of_stock ? 'action-btn-disabled' : ''}}" bindtap="onAddToCart">
    <text>{{product.out_of_stock ? '暂时缺货' : '加入购物车'}}</text>
  </view>
  <view class="action-btn action-btn-buy {{product.out_of_stock ? 'action-btn-disabled' : ''}}" bindtap="onBuyNow">
    <text>{{product.out_of_stock ? '暂时缺货' : '立即购买'}}</text>
  </view>
</view>
