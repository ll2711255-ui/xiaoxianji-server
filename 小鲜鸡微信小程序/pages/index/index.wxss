/* ========== 搜索全屏浮层 ========== */
.search-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #F5F5F5;
  z-index: 200;
  display: flex;
  flex-direction: column;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: #fff;
  gap: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.search-header-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F0F0F0;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
}

.search-header-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #999;
  flex-shrink: 0;
}

.search-header-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.search-ph-cls {
  color: #B0B0B0;
  font-size: 32rpx;
}

.search-header-clear {
  font-size: 32rpx;
  color: #C7C7CC;
  padding: 8rpx;
  flex-shrink: 0;
}

.search-header-cancel {
  font-size: 32rpx;
  color: #1DB96A;
  flex-shrink: 0;
  padding: 8rpx 0;
}

/* 搜索主体 */
.search-body {
  flex: 1;
  overflow: hidden;
}

/* 搜索结果 */
.search-results {
  padding: 16rpx 24rpx;
}

.search-result-card {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  background: #F5F5F5;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  padding: 16rpx;
  background: #fff;
}

.search-result-card:active {
  background: #F5F5F5;
}

.sri-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 10rpx;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.sri-img {
  width: 100%;
  height: 100%;
}

.sri-emoji {
  font-size: 54rpx;
}

.sri-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.sri-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sri-desc {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 4rpx;
}

.sri-price {
  display: flex;
  align-items: baseline;
  margin-top: 4rpx;
}

.sri-price .price-symbol {
  font-size: 26rpx;
  color: #FF4B26;
  font-weight: 700;
}

.sri-price .price-value {
  font-size: 34rpx;
  color: #FF4B26;
  font-weight: 700;
  line-height: 1;
}

.sri-price .price-unit {
  font-size: 24rpx;
  color: #AAA;
  margin-left: 4rpx;
}

/* 搜索空结果 */
.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.search-empty-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.search-empty-text {
  font-size: 32rpx;
  color: #999;
}

.search-empty-hint {
  font-size: 28rpx;
  color: #C7C7CC;
  margin-top: 12rpx;
}

/* 搜索历史 */
.search-history {
  padding: 24rpx;
}

.search-history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-history-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.search-history-clear {
  font-size: 28rpx;
  color: #999;
}

.search-history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-history-tag {
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #666;
  border: 1px solid #EEE;
}

.search-history-tag:active {
  background: #F0F0F0;
}

/* 热门搜索 */
.search-hot {
  padding: 24rpx;
}

.search-hot-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.search-hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-hot-tag {
  padding: 12rpx 28rpx;
  background: #FFF0EB;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #FF5722;
}

.search-hot-tag:active {
  background: #FFE0D6;
}

/* ========== 页面全局 ========== */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F5F5;
  overflow: hidden;
}

/* ========== 顶部搜索栏 ========== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  gap: 20rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F0F0F0;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-placeholder {
  font-size: 30rpx;
  color: #B0B0B0;
}

.brand-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1DB96A;
  flex-shrink: 0;
}

/* ========== Banner 轮播 ========== */
.banner-swiper {
  flex-shrink: 0;
  height: 180rpx;
  margin: 16rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-slide {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  height: 100%;
  box-sizing: border-box;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.banner-sub {
  font-size: 28rpx;
  color: #888;
  margin-top: 8rpx;
}

.banner-emoji {
  font-size: 88rpx;
}

/* ========== 左右联动主体 ========== */
.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

/* ========== 左侧分类导航 ========== */
.left-nav {
  width: 180rpx;
  background: #FAFAFA;
  flex-shrink: 0;
}

.cate-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 0 12rpx;
}

.cate-bar {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background: #FF6B35;
  border-radius: 0 3rpx 3rpx 0;
}

.cate-name {
  font-size: 30rpx;
  color: #666;
}

.cate-active {
  background: #fff;
}

.cate-active .cate-name {
  color: #FF6B35;
  font-weight: 700;
}

/* ========== 右侧商品列表 ========== */
.right-scroll {
  flex: 1;
  background: #fff;
  padding: 0 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  padding: 24rpx 0 16rpx;
}

/* ========== 商品卡片（单列横向） ========== */
.goods-card {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.goods-card:active {
  opacity: 0.9;
}

/* 缺货商品卡片 */
.goods-card.goods-out-of-stock {
  opacity: 0.65;
}

/* 缺货遮罩 */
.out-of-stock-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}
.out-of-stock-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  padding: 8rpx 24rpx;
  border: 2px solid rgba(255, 255, 255, 0.8);
  border-radius: 8rpx;
}

.goods-img-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #F5F5F5;
}

.goods-img {
  width: 100%;
  height: 100%;
}

.goods-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: #f9f9f9;
}

/* 右侧信息区 */
.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.goods-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}

.goods-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.goods-sales-tag {
  font-size: 24rpx;
  color: #FF6B35;
  margin-top: 8rpx;
}

.goods-price {
  display: flex;
  align-items: baseline;
  margin-top: 4rpx;
}

.goods-price .price-symbol {
  font-size: 26rpx;
  color: #FF4B26;
  font-weight: 700;
}

.goods-price .price-value {
  font-size: 36rpx;
  color: #FF4B26;
  font-weight: 700;
  line-height: 1;
}

.goods-price .price-unit {
  font-size: 24rpx;
  color: #AAA;
  margin-left: 4rpx;
  flex-shrink: 0;
}

/* ========== 底部购物车浮栏 ========== */
.cart-float {
  position: fixed;
  bottom: 16rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #333;
  border-radius: 48rpx;
  padding: 14rpx 24rpx;
  z-index: 100;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.cart-float-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cart-float-icon {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  background: #1DB96A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 30rpx;
  height: 30rpx;
  background: #FF4B26;
  color: #fff;
  font-size: 22rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5rpx;
  line-height: 1;
}

.cart-float-total {
  font-size: 34rpx;
  color: #fff;
  font-weight: 700;
}

.cart-float-btn {
  background: #1DB96A;
  color: #fff;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* ========== 加载中状态 ========== */
.loading-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E8E8E8;
  border-top-color: #1DB96A;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #999;
}

/* ========== 加载失败状态 ========== */
.error-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.error-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 32rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.error-retry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 240rpx;
  height: 72rpx;
  background: #1DB96A;
  border-radius: 36rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.error-retry-btn:active {
  opacity: 0.85;
}

/* ========== 商品为空状态 ========== */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #C7C7CC;
  text-align: center;
}

