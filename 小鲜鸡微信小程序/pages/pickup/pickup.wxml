<view class="pu-page">
  <!-- 加载中 -->
  <view class="pu-center" wx:if="{{isLoading}}">
    <view class="pu-spinner"></view>
    <text class="pu-text">加载中...</text>
  </view>

  <!-- 无效 -->
  <view class="pu-center" wx:elif="{{isInvalid}}">
    <view class="pu-invalid-circle">
      <text class="pu-invalid-x">✕</text>
    </view>
    <text class="pu-invalid-title">无效的取货码</text>
    <text class="pu-hint" style="margin-top:12rpx;">请确认二维码是否正确</text>
  </view>

  <!-- 已完成（可以取货）- 全屏绿色 -->
  <view class="pu-completed" wx:elif="{{isCompleted}}">
    <view class="pu-success-circle">
      <text class="pu-success-check">✓</text>
    </view>
    <text class="pu-success-title">可以取货了</text>
    <text class="pu-detail-light">订单号：{{orderDisplay}}</text>
    <text class="pu-cardnum" wx:if="{{cardNumber}}">{{cardNumber}}</text>
    <text class="pu-cardlabel" wx:if="{{cardNumber}}">号码牌</text>
    <text class="pu-hint-light">请到前台凭号码牌取货</text>
  </view>

  <!-- 处理中 - 白色卡片 -->
  <view class="pu-center" wx:else>
    <view class="pu-processing-card">
      <view class="pu-spinner"></view>
      <text class="pu-processing-text">商品处理中，请稍候...</text>
      <text class="pu-detail">订单号：{{orderDisplay}}</text>
      <text class="pu-cardnum-dark" wx:if="{{cardNumber}}">{{cardNumber}}</text>
      <text class="pu-cardlabel" wx:if="{{cardNumber}}">号码牌</text>
    </view>
  </view>

  <!-- 离线 / 刷新 -->
  <view class="pu-offline" wx:if="{{isOffline && !isInvalid}}">
    <text class="pu-offline-text">网络不稳定，显示最后状态</text>
  </view>
  <view class="pu-refresh" wx:if="{{showRefreshBtn && !isInvalid}}">
    <view class="btn-outline" bindtap="onRefresh">手动刷新</view>
  </view>
</view>
