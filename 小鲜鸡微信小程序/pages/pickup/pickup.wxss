/* ========== 取货状态页 ========== */
.pu-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

.pu-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 48rpx;
}

/* ========== 加载动画 ========== */
.pu-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: var(--radius-full);
  animation: pu-spin 1s linear infinite;
}

@keyframes pu-spin {
  to { transform: rotate(360deg); }
}

.pu-text {
  margin-top: 24rpx;
  font-size: var(--font-base);
  color: var(--color-text-3);
}

/* ========== 无效 ========== */
.pu-invalid-circle {
  width: 144rpx;
  height: 144rpx;
  border: 4rpx solid var(--color-danger);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pu-invalid-x {
  font-size: 80rpx;
  color: var(--color-danger);
}

.pu-invalid-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-danger);
  margin-top: 24rpx;
}

/* ========== 已完成（可取货）- 全屏绿色 ========== */
.pu-completed {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: var(--color-primary);
  padding: 48rpx;
}

.pu-success-circle {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255,255,255,0.2);
  border: 6rpx solid #fff;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.pu-success-check {
  font-size: 88rpx;
  color: #fff;
  font-weight: 700;
}

.pu-success-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}

.pu-detail-light {
  font-size: var(--font-base);
  color: rgba(255,255,255,0.8);
  margin-top: 20rpx;
}

.pu-hint-light {
  font-size: var(--font-md);
  color: rgba(255,255,255,0.6);
  margin-top: 28rpx;
}

/* 已完成状态的号码牌 */
.pu-cardnum {
  font-size: 64rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  margin-top: 24rpx;
}

/* ========== 处理中 - 白色卡片 ========== */
.pu-processing-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 64rpx 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 560rpx;
}

.pu-processing-text {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-1);
  margin-top: 32rpx;
}

.pu-cardnum-dark {
  font-size: 64rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
  margin-top: 16rpx;
}

/* ========== 通用 ========== */
.pu-detail {
  font-size: var(--font-base);
  color: var(--color-text-3);
  margin-top: 16rpx;
}

.pu-cardlabel {
  font-size: var(--font-md);
  color: var(--color-text-3);
  margin-top: 6rpx;
}

.pu-hint {
  font-size: var(--font-md);
  color: var(--color-text-3);
}

/* ========== 离线 / 刷新 ========== */
.pu-offline {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: var(--color-primary-pale);
  text-align: center;
  padding: 12rpx;
  z-index: 10;
}

.pu-offline-text {
  font-size: var(--font-md);
  color: var(--color-warning);
}

.pu-refresh {
  text-align: center;
  padding: 32rpx;
}
