/* ========== 订单列表页 ========== */
.orders-page {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* Tab 行 */
.tab-row {
  display: flex;
  background: var(--color-bg-card);
  padding: 0 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--font-base);
  color: var(--color-text-3);
  position: relative;
}

.tab.on {
  color: var(--color-primary);
  font-weight: 700;
}

.tab.on::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: var(--radius-sm);
}

/* ========== 卡片列表 ========== */
.orders-body {
  padding: 16rpx 24rpx;
}

.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 头部 */
.oc-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.oc-head-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.oc-no {
  font-size: var(--font-base);
  color: var(--color-text-3);
}

.oc-time {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}

.oc-status {
  font-size: var(--font-md);
  font-weight: 600;
}

.oc-status.tag-green {
  background: var(--color-success-bg);
  color: var(--color-primary);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
}

.oc-status.tag-orange {
  background: var(--color-primary-pale);
  color: var(--color-warning);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
}

.oc-status.tag-gray {
  background: var(--color-bg-page);
  color: var(--color-text-3);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
}

.oc-status.tag-red {
  background: var(--color-danger-bg);
  color: var(--color-danger);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
}

/* 商品行 */
.oc-items {
  padding: 16rpx 0;
  border-top: 1rpx solid var(--color-border);
  border-bottom: 1rpx solid var(--color-border);
}

.oc-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  gap: 12rpx;
}

.oc-pname {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--color-text-1);
}

.oc-pspec {
  font-size: var(--font-md);
  color: var(--color-text-3);
}

.oc-pqty {
  margin-left: auto;
  font-size: var(--font-md);
  color: var(--color-text-3);
  flex-shrink: 0;
}

/* 取货号码 & 称重信息 */
.oc-extras {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid var(--color-border);
}

.oc-card-num {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--color-success-bg);
  padding: 10rpx 18rpx;
  border-radius: var(--radius-md);
}

.oc-card-num-label {
  font-size: var(--font-sm);
  color: var(--color-primary);
}

.oc-card-num-value {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.oc-weigh-thumb {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.oc-weigh-thumb-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
}

.oc-weigh-thumb-text {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}

.oc-weigh-mini {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.oc-weigh-mini-icon {
  font-size: var(--font-base);
  opacity: 0.6;
}

.oc-weigh-mini-label {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}

/* 底部 */
.oc-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.oc-alabel {
  font-size: var(--font-md);
  color: var(--color-text-3);
}

.oc-actions {
  display: flex;
  gap: 16rpx;
}

.oc-action {
  font-size: var(--font-md);
  color: var(--color-text-3);
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
}

.oc-action-primary {
  color: #fff;
  border-color: var(--color-brand-chili-red);
  background: linear-gradient(to right, var(--color-brand-main-red), var(--color-brand-chili-red));
  box-shadow: 0 4rpx 12rpx var(--color-brand-soy-red-shadow);
}

.oc-action-pay {
  color: #fff;
  border-color: var(--color-primary);
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary));
}
