<view class="orders-page">
  <!-- 顶部 Tab -->
  <view class="tab-row">
    <view
      class="tab {{tabIndex === index ? 'on' : ''}}"
      wx:for="{{tabs}}"
      wx:key="*this"
      data-index="{{index}}"
      bindtap="onTabTap"
    >{{item}}</view>
  </view>

  <!-- 订单列表 -->
  <view class="orders-body" wx:if="{{orders.length > 0}}">
    <view
      class="order-card"
      wx:for="{{orders}}"
      wx:key="_id"
      data-order-no="{{item.orderNo}}"
      bindtap="onOrderTap"
    >
      <!-- 头部 -->
      <view class="oc-head">
        <view class="oc-head-left">
          <text class="oc-no">{{item.orderNo}}</text>
          <text class="oc-time">{{item.createTime}}</text>
        </view>
        <text class="oc-status {{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <!-- 商品 -->
      <view class="oc-items">
        <view class="oc-item" wx:for="{{item.items}}" wx:for-item="p" wx:key="index">
          <text class="oc-pname">{{p.productName}}</text>
          <text class="oc-pspec" wx:if="{{p.spec}}">{{p.spec.type || ''}}{{p.spec.weight ? ' ' + p.spec.weight : ''}} {{p.spec.processing || ''}}</text>
          <text class="oc-pqty">×{{p.quantity}}</text>
        </view>
      </view>

      <!-- 取货号码 & 称重信息 -->
      <view class="oc-extras" wx:if="{{item.cardNumber || item.actualWeight || item.weighPhoto || item.status === 'weighed'}}">
        <!-- 取货号码牌 -->
        <view class="oc-card-num" wx:if="{{item.type === 'pickup' && item.cardNumber}}">
          <text class="oc-card-num-label">取货号码</text>
          <text class="oc-card-num-value">{{item.cardNumber}}</text>
        </view>
        <!-- 称重照片缩略图 -->
        <view class="oc-weigh-thumb" wx:if="{{item.weighPhoto}}">
          <image class="oc-weigh-thumb-img" src="{{item.weighPhoto}}" mode="aspectFill" />
          <text class="oc-weigh-thumb-text">称重照片</text>
        </view>
        <!-- 已称重提示（无照片时） -->
        <view class="oc-weigh-mini" wx:elif="{{item.actualWeight || item.status === 'weighed'}}">
          <text class="oc-weigh-mini-icon">📷</text>
          <text class="oc-weigh-mini-label">已称重{{item.actualWeight ? ' ' + item.actualWeight + 'g' : ''}}</text>
        </view>
      </view>

      <!-- 底部 -->
      <view class="oc-foot">
        <text class="oc-alabel">预估 ¥{{item.prepayDisplay}}</text>
        <view class="oc-actions">
          <text class="oc-action oc-action-pay" wx:if="{{item.status === 'pending'}}" catchtap="onPayOrder" data-order-no="{{item.orderNo}}">去支付</text>
          <text class="oc-action" wx:if="{{item.status === 'pending' || item.status === 'paid'}}" catchtap="onCancelOrderItem" data-order-no="{{item.orderNo}}">取消订单</text>
          <text class="oc-action oc-action-primary">查看详情</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空 / 加载 -->
  <view class="empty-state" wx:if="{{orders.length === 0 && !loading}}">
    <text class="empty-icon">📋</text>
    <text>暂无订单</text>
  </view>
  <view class="load-more" wx:if="{{loading}}">加载中...</view>
</view>

<!-- 手机号授权浮层（支付前） -->
<view class="phone-auth-overlay" wx:if="{{showPhoneAuth}}">
  <view class="phone-auth-mask" catchtap="onCancelPhoneAuth"></view>
  <view class="phone-auth-card">
    <text class="phone-auth-title">绑定手机号</text>
    <text class="phone-auth-desc">支付前需要绑定手机号，方便商家联系您</text>
    <button class="phone-auth-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneForOrder">
      微信手机号一键授权
    </button>
    <view class="phone-auth-cancel" bindtap="onCancelPhoneAuth">
      <text>暂不绑定</text>
    </view>
  </view>
</view>

<!-- Custom TabBar -->
<custom-tab-bar current="orders" theme="customer" bind:change="onTabChange" />
