/* ========== 订单详情页 ========== */

/* 状态头部 - 绿色 */
.od-header {
  background: linear-gradient(160deg, var(--color-primary), var(--color-success));
  padding: 48rpx 32rpx;
  text-align: center;
}

.od-status {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.od-desc {
  font-size: var(--font-base);
  color: rgba(255,255,255,0.85);
  margin-top: 10rpx;
  display: block;
}

/* 号码牌 */
.od-pickup {
  text-align: center;
  padding: 36rpx 24rpx;
}

.pickup-tag {
  font-size: var(--font-md);
  color: var(--color-text-3);
  display: block;
}

.pickup-num {
  font-size: 104rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1.2;
  display: block;
  margin: 8rpx 0;
}

.pickup-hint {
  font-size: var(--font-base);
  color: var(--color-text-3);
  display: block;
}

/* 区块标题 */
.od-section-title {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-text-1);
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

/* 商品行 */
.od-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}

.od-item + .od-item {
  border-top: 1rpx solid var(--color-border);
}

.od-item-left {
  flex: 1;
}

.od-pname {
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--color-text-1);
  display: block;
}

.od-ptags {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.od-item-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.od-pqty {
  font-size: var(--font-md);
  color: var(--color-text-3);
  display: block;
}

.od-pprice {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
  margin-top: 6rpx;
  display: block;
}

/* 称重照片 */
.weigh-photo-section {
  text-align: center;
  margin-bottom: 20rpx;
}

.weigh-photo {
  width: 100%;
  max-width: 500rpx;
  height: 400rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
}

.weigh-photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 280rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--color-border);
}

.weigh-photo-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.weigh-photo-text {
  font-size: var(--font-md);
  color: var(--color-text-3);
}

.weigh-photo-hint {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  display: block;
  margin-top: 10rpx;
}

/* 信息行 */
.od-inforow {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  font-size: var(--font-base);
}

.od-infol {
  color: var(--color-text-3);
  flex-shrink: 0;
}

.od-infor {
  color: var(--color-text-1);
}

.od-price {
  color: var(--color-primary);
  font-weight: 700;
}

.od-addr {
  text-align: right;
  flex: 1;
}

/* 可点击的行内容（地址导航 / 电话拨号） */
.od-clickable {
  color: var(--color-primary);
}

.od-clickable:active {
  opacity: 0.6;
}

.od-action-icon {
  font-size: var(--font-base);
  margin-left: 6rpx;
}

.od-refund {
  margin-top: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}

.od-refund-amount {
  color: var(--color-primary);
  font-weight: 700;
}

/* 操作按钮区 */
.od-actions {
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 去支付按钮 — 填充品牌色 */
.od-pay {
  text-align: center;
  padding: 24rpx;
  color: #fff;
  font-size: var(--font-lg);
  font-weight: 600;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary));
  border-radius: var(--radius-full);
}

.od-pay:active {
  opacity: 0.85;
}

/* 取消按钮 */
.od-cancel {
  text-align: center;
  padding: 24rpx;
  color: var(--color-danger);
  font-size: var(--font-base);
  border: 2rpx solid var(--color-danger);
  border-radius: var(--radius-full);
  background: var(--color-bg-card);
}

.od-cancel:active {
  background: var(--color-primary-pale);
}

/* 离线提示 */
.od-offline {
  text-align: center;
  padding: 24rpx;
  background: var(--color-primary-pale);
  margin: 16rpx 24rpx;
  border-radius: var(--radius-md);
}

.od-offline-text {
  font-size: var(--font-md);
  color: var(--color-warning);
  display: block;
}
