# ========== 数据库 ==========
DATABASE_URL="mysql://xiaoxianji:你的数据库密码@localhost:3306/xiaoxianji"

# ========== Redis ==========
REDIS_URL="redis://localhost:6379"

# ========== JWT ==========
JWT_SECRET="请生成一个64位随机字符串替换此处"
JWT_REFRESH_SECRET="请生成另一个64位随机字符串替换此处"

# ========== 服务端口 ==========
PORT=3000

# ========== 微信小程序 ==========
WX_APPID="wx178d0ae59d576ce1"
WX_APP_SECRET="你的小程序AppSecret"

# ========== 微信支付 APIv3 ==========
# ⚠️ 安全警告：以下密钥请通过微信商户平台获取
# 商户平台 → 账户中心 → API安全 → API证书/APIv3密钥
WXPAY_MCHID="你的商户号"
WXPAY_SERIAL_NO="你的证书序列号"
WXPAY_APIv3_KEY="你的APIv3密钥"

# 商户私钥（PEM格式，生产环境建议用文件路径）
# 如果是单行：直接填入
# 如果是多行：将 \n 替换为真实换行，或用 base64 编码
WXPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n你的私钥内容\n-----END PRIVATE KEY-----"

# 微信支付平台证书保存路径（可选）
WXPAY_PLATFORM_CERT_PATH="./certs/platform_certs.json"

# ========== 阿里云 OSS ==========
OSS_REGION="oss-cn-guangzhou"
OSS_ACCESS_KEY="你的AccessKey"
OSS_SECRET_KEY="你的SecretKey"
OSS_BUCKET="xiaoxianji"

# ========== 腾讯地图 ==========
QQ_MAP_KEY="你的腾讯地图Key"

# ========== 日志 ==========
LOG_LEVEL="info"
# 开发环境可设为 debug
# LOG_LEVEL="debug"
