generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 商户表
// ============================================================
model Merchant {
  id             BigInt    @id @default(autoincrement())
  name           String    @db.VarChar(128)
  address        String?   @db.VarChar(256)
  lat            Decimal?  @db.Decimal(10, 6)
  lng            Decimal?  @db.Decimal(10, 6)
  deliveryRadius Int?      @default(5)                    // 配送半径(km)
  contactName    String?   @db.VarChar(64)
  contactPhone   String?   @db.VarChar(20)
  openTime       String?   @db.VarChar(8)                 // HH:mm
  closeTime      String?   @db.VarChar(8)                 // HH:mm
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  users             User[]
  products          Product[]
  categories        Category[]
  orders            Order[]
  banners           Banner[]
  paiNumbers        PaiNumber[]
  storeConfigs      StoreConfig[]
  merchantAccounts  MerchantAccount[]

  @@map("merchants")
}

// ============================================================
// 商家登录账号
// ============================================================
model MerchantAccount {
  id           BigInt    @id @default(autoincrement())
  merchantId   BigInt    @map("merchant_id")
  phone        String    @unique @db.VarChar(20)
  passwordHash String    @map("password_hash") @db.VarChar(128)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@map("merchant_accounts")
}

// ============================================================
// 用户表（小程序端）
// ============================================================
model User {
  id         BigInt    @id @default(autoincrement())
  openid     String    @unique @db.VarChar(64)
  unionid    String?   @db.VarChar(64)
  phone      String?   @db.VarChar(20)
  nickName   String?   @map("nick_name") @db.VarChar(64)
  avatarUrl  String?   @map("avatar_url") @db.VarChar(512)
  role       Role      @default(customer)
  merchantId BigInt?   @map("merchant_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  merchant  Merchant? @relation(fields: [merchantId], references: [id])
  orders    Order[]
  addresses Address[]

  @@map("users")
}

enum Role {
  customer
  merchant
  admin
}

// ============================================================
// 商品分类
// ============================================================
model Category {
  id         BigInt   @id @default(autoincrement())
  merchantId BigInt   @map("merchant_id")
  name       String   @db.VarChar(64)
  sort       Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  merchant Merchant  @relation(fields: [merchantId], references: [id])
  products Product[]

  @@index([merchantId, sort])
  @@map("categories")
}

// ============================================================
// 商品
// ============================================================
model Product {
  id            BigInt      @id @default(autoincrement())
  merchantId    BigInt      @map("merchant_id")
  categoryId    BigInt?     @map("category_id")
  name          String      @db.VarChar(128)
  pricingType   PricingType @map("pricing_type")
  pricePerJin   Decimal?    @map("price_per_jin") @db.Decimal(10, 2)
  unitPrice     Decimal?    @map("unit_price") @db.Decimal(10, 2)
  // JSON: [{grams:500,label:"500g/1斤",price:null}]
  weightOptions Json?       @map("weight_options")
  // JSON: [{label:"毛鸡称重",weights:[{label:"2-2.5斤",maxGrams:1250}]}]
  typeConfigs   Json?       @map("type_configs")
  // JSON: [{label:"整只",fee:0},{label:"切块",fee:2}]
  processingOptions Json?   @map("processing_options")
  // JSON: ["delivery","pickup"]
  deliveryModes Json?       @map("delivery_modes")
  // JSON: ["https://..."， "https://..."]
  images        Json?
  description   String?     @db.Text
  sellingPoint  String?     @map("selling_point") @db.VarChar(256)
  outOfStock    Boolean     @default(false) @map("out_of_stock")
  status        ProductStatus @default(on)
  sales         Int         @default(0)
  sort          Int         @default(0)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  merchant  Merchant  @relation(fields: [merchantId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([merchantId, categoryId])
  @@index([merchantId, status])
  @@map("products")
}

enum PricingType {
  exact_weight
  range_weight
  per_piece
}

enum ProductStatus {
  on
  off
}

// ============================================================
// 订单
// ============================================================
model Order {
  id            BigInt      @id @default(autoincrement())
  orderNo       String      @unique @map("order_no") @db.VarChar(32)
  userId        BigInt?     @map("user_id")
  merchantId    BigInt      @map("merchant_id")
  type          OrderType
  status        OrderStatus @default(pending)

  // 金额（单位：分）
  prepayAmount  Int         @default(0) @map("prepay_amount")
  actualAmount  Int?        @map("actual_amount")
  refundAmount  Int?        @map("refund_amount")
  refundStatus  RefundStatus @default(none) @map("refund_status")

  // 支付信息
  transactionId String?     @map("transaction_id") @db.VarChar(64)
  payTime       DateTime?   @map("pay_time")

  // 配送信息
  deliveryAddress Json?     @map("delivery_address")
  deliveryTime    DateTime? @map("delivery_time")
  deliveryFee     Int       @default(0) @map("delivery_fee")

  // 履约信息
  pickupTime   DateTime?    @map("pickup_time")
  cardNumber   String?      @map("card_number") @db.VarChar(8)
  token        String?      @db.VarChar(32)

  // 称重信息（JSON：{grams,pricePerJin,processingFee,photoUrl}）
  weighInfo    Json?        @map("weigh_info")

  // 退款信息（JSON：{refundId,refundAmount,status,retryCount,lastError}）
  refundInfo   Json?        @map("refund_info")

  // 物流信息（JSON：{waybillId,carrier,trackingNo}）
  shippingInfo Json?        @map("shipping_info")
  shippingUploaded Boolean  @default(false) @map("shipping_uploaded")

  // 支付方式（线下订单：cash / wechat / unpaid）
  paymentMethod String?     @map("payment_method") @db.VarChar(16)

  // 状态时间戳
  acceptTime   DateTime?    @map("accept_time")
  completeTime DateTime?    @map("complete_time")
  cancelTime   DateTime?    @map("cancel_time")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id])
  merchant Merchant   @relation(fields: [merchantId], references: [id])
  items   OrderItem[]

  @@index([userId, createdAt])
  @@index([merchantId, status])
  @@index([merchantId, type])
  @@index([merchantId, createdAt])
  @@index([cardNumber])
  @@map("orders")
}

enum OrderType {
  delivery
  pickup
  offline
}

enum OrderStatus {
  pending
  paid
  accepted
  weighed
  processing
  ready
  delivering
  completed
  cancelled
}

enum RefundStatus {
  none
  processing
  success
  failed
}

// ============================================================
// 订单明细（商品快照）
// ============================================================
model OrderItem {
  id           BigInt   @id @default(autoincrement())
  orderId      BigInt   @map("order_id")
  productId    BigInt?  @map("product_id")
  productName  String   @map("product_name") @db.VarChar(128)
  pricingType  PricingType @map("pricing_type")
  // JSON：规格快照 {type,weightLabel,weightGrams,processing,deliveryMode,unitPrice,pricePerJin,processingFee}
  spec         Json
  quantity     Int      @default(1)
  itemAmount   Int      @map("item_amount")  // 该明细预支付金额(分)
  createdAt    DateTime @default(now()) @map("created_at")

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================================
// 用户地址
// ============================================================
model Address {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  name       String   @db.VarChar(32)
  phone      String   @db.VarChar(20)
  province   String   @db.VarChar(32)
  city       String   @db.VarChar(32)
  district   String   @db.VarChar(32)
  detail     String   @db.VarChar(256)
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("addresses")
}

// ============================================================
// 号码牌
// ============================================================
model PaiNumber {
  id         BigInt  @id @default(autoincrement())
  merchantId BigInt  @map("merchant_id")
  number     String  @db.VarChar(8)
  status     PaiStatus @default(idle)
  orderId    BigInt? @map("order_id")

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, number])
  @@index([merchantId, status])
  @@map("pai_numbers")
}

enum PaiStatus {
  idle
  in_use
}

// ============================================================
// 小程序码
// ============================================================
model CardCode {
  id              BigInt   @id @default(autoincrement())
  merchantId      BigInt   @map("merchant_id")
  cardNumber      String   @map("card_number") @db.VarChar(8)
  codeImageUrl    String   @map("code_image_url") @db.VarChar(512)
  scene           String   @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([merchantId, cardNumber])
  @@map("card_codes")
}

// ============================================================
// 轮播图
// ============================================================
model Banner {
  id         BigInt   @id @default(autoincrement())
  merchantId BigInt   @map("merchant_id")
  image      String   @db.VarChar(512)
  link       String?  @db.VarChar(512)
  sort       Int      @default(0)
  status     BannerStatus @default(on)
  createdAt  DateTime @default(now()) @map("created_at")

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@map("banners")
}

enum BannerStatus {
  on
  off
}

// ============================================================
// 门店配置（KV 结构）
// ============================================================
model StoreConfig {
  id         BigInt   @id @default(autoincrement())
  merchantId BigInt   @map("merchant_id")
  configKey  String   @map("config_key") @db.VarChar(64)
  configValue Json    @map("config_value")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([merchantId, configKey])
  @@map("store_configs")
}

// ============================================================
// 序号计数器（订单号生成）
// ============================================================
model Counter {
  id    BigInt @id @default(autoincrement())
  key   String @unique @db.VarChar(32)
  value Int    @default(0)

  @@map("counters")
}

// ============================================================
// 支付通知日志
// ============================================================
model PaymentLog {
  id          BigInt   @id @default(autoincrement())
  orderNo     String   @map("order_no") @db.VarChar(32)
  eventType   String   @map("event_type") @db.VarChar(32)
  rawBody     String?  @map("raw_body") @db.Text
  status      String   @db.VarChar(16)
  errorMsg    String?  @map("error_msg") @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orderNo])
  @@map("payment_logs")
}

// ============================================================
// 登录尝试记录（限流）
// ============================================================
model LoginAttempt {
  id        BigInt   @id @default(autoincrement())
  phone     String   @db.VarChar(20)
  success   Boolean
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, createdAt])
  @@map("login_attempts")
}
