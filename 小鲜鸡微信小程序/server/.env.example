# ==========================================================================
# 小鲜鸡服务端 · 环境变量
# 复制为 .env 并填入真实值
# ==========================================================================

# ---- 服务器 ----
NODE_ENV=development
PORT=3000

# ---- 数据库 ----
DB_HOST=127.0.0.
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=xiaoxianji

# ---- JWT ----
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=12h

# ---- 微信小程序 ----
WX_APPID=wx178d0ae59d576ce1
WX_SECRET=your_app_secret

# ---- 微信支付 APIv3 ----
WXPAY_MCHID=1747616717
WXPAY_SERIAL_NO=19D5277A47D00063462404515E4C02E3B49F1A6E
WXPAY_APIv3_KEY=your_apiv3_key
WXPAY_PRIVATE_KEY_PATH=/etc/wechatpay/apiclient_key.pem
WXPAY_NOTIFY_URL=https://your-domain.com/api/v1/callback/pay
WXPAY_REFUND_NOTIFY_URL=https://your-domain.com/api/v1/callback/refund

# ---- 腾讯云 COS ----
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=xiaoxianji-xxxxx
COS_REGION=ap-guangzhou

# ---- 订阅消息模板 ----
SUBSCRIBE_TEMPLATE_ID=Y1RwzBFfh75DI7yyXs0_-pAWpUqoGVvbdKNjqzsw4HE
