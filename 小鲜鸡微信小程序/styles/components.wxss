/* ================================================================
   组件样式规范 — styles/components.wxss
   第三步：全量组件库（暖橙主题，全部走 tokens.wxss 变量）
   说明：本文件由 app.wxss @import 引入，作为全局官方组件库。
   现有 wxml 已用到的类（btn-primary/order-card/search-bar/
   action-bar/product-card 等）立即生效；其余为待用组件，
   新页面/重构时可直接套用，无需重复造轮子。
   ⚠️ 不改任何 .wxml / .js —— 类名保持与规范一致。
   ================================================================ */

/* ================================================================
   一、按钮
   ================================================================ */

/* 主按钮 */
.btn-primary {
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: var(--weight-medium);
  padding: 0 var(--space-xl);
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 次按钮 */
.btn-secondary {
  background: var(--color-bg-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-full);
  font-size: var(--font-base);
  font-weight: var(--weight-medium);
  padding: 0 var(--space-xl);
  height: 88rpx;
  line-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 幽灵按钮 */
.btn-ghost {
  background: var(--color-primary-pale);
  color: var(--color-primary-dark);
  border: none;
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
  padding: 0 var(--space-md);
  height: 64rpx;
  line-height: 64rpx;
}

/* 加减号购买按钮 */
.btn-add {
  width: 56rpx;
  height: 56rpx;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  color: #FFFFFF;
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

/* ================================================================
   二、状态标签
   ================================================================ */

/* 通用标签基础 */
.tag {
  display: inline-flex;
  align-items: center;
  border-radius: var(--radius-full);
  padding: 4rpx 16rpx;
  font-size: var(--font-xs);
  font-weight: var(--weight-medium);
}

/* 各状态颜色 — modifier */
.tag-pending    { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-paid       { background: var(--color-primary-pale); color: var(--color-primary-dark); }
.tag-delivering { background: var(--color-primary-pale); color: var(--color-primary); }
.tag-done       { background: var(--color-success-bg); color: var(--color-success); }
.tag-cancelled  { background: var(--color-bg-input); color: var(--color-text-3); }

/* ================================================================
   三、商品卡片
   ================================================================ */

.product-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.product-card .img-wrap {
  background: var(--color-bg-page);
  /* 宽高保持原 wxml 结构不变 */
}

.product-card .name {
  font-size: var(--font-base);
  font-weight: var(--weight-medium);
  color: var(--color-text-1);
}

.product-card .desc {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}

.product-card .price {
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
  color: var(--color-primary);
}

.product-card .price-unit {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  font-weight: var(--weight-normal);
}

.product-card .price-old {
  font-size: var(--font-sm);
  color: var(--color-text-3);
  text-decoration: line-through;
}

/* ================================================================
   四、促销角标
   ================================================================ */

.badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  border-radius: var(--radius-sm);
  padding: 4rpx 10rpx;
  font-size: var(--font-xs);
  font-weight: var(--weight-medium);
}
.badge-new { background: var(--color-primary); color: #fff; }
.badge-hot { background: var(--color-danger); color: #fff; }
.badge-off { background: var(--color-danger); color: #fff; }

/* ================================================================
   五、搜索栏
   ================================================================ */

.search-bar {
  background: var(--color-bg-input);
  border-radius: var(--radius-full);
  height: 72rpx;
  display: flex;
  align-items: center;
  padding: 0 var(--space-md);
  gap: var(--space-xs);
}
.search-bar .placeholder {
  font-size: var(--font-md);
  color: var(--color-text-3);
}

/* ================================================================
   六、分类筛选条
   ================================================================ */

.category-tab {
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
}
.category-tab.active {
  background: var(--color-primary);
  color: #FFFFFF;
}
.category-tab.inactive {
  background: var(--color-bg-input);
  color: var(--color-text-2);
}

/* ================================================================
   七、订单卡片
   ================================================================ */

.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
}
.order-card .header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}
.order-card .order-no {
  font-size: var(--font-sm);
  color: var(--color-text-3);
}
.order-card .total {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
}

/* ================================================================
   八、表单输入
   ================================================================ */

.input-wrap {
  background: var(--color-bg-input);
  border-radius: var(--radius-md);
  padding: var(--space-sm) var(--space-md);
  border: 2rpx solid transparent;
}
.input-wrap.focused {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
}
.input-field {
  font-size: var(--font-base);
  color: var(--color-text-1);
}

/* ================================================================
   九、页面顶部自定义 Header
   ================================================================ */

.page-header {
  background: #FFFFFF;
  padding: var(--space-sm) var(--space-md);
  border-bottom: 1rpx solid var(--color-border);
}
.page-title {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
  color: var(--color-text-1);
}

/* ================================================================
   十、列表分隔（伪元素，减少 DOM 节点）
   ================================================================ */

.list-item::after {
  content: '';
  display: block;
  height: 1rpx;
  background: var(--color-border);
  margin: 0 var(--space-md);
}

/* ================================================================
   十一、空状态页
   ================================================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) 0;
  gap: var(--space-md);
}
.empty-state .tip {
  font-size: var(--font-md);
  color: var(--color-text-3);
}

/* ================================================================
   十二、底部操作栏（结算栏）
   ================================================================ */

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border);
  padding: var(--space-sm) var(--space-md);
  padding-bottom: calc(var(--space-sm) + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ================================================================
   十三、促销 Banner
   ================================================================ */

.promo-banner {
  background: var(--color-primary-pale);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-primary-light);
  padding: var(--space-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--space-sm) var(--space-md);
}
.promo-banner .title {
  font-size: var(--font-lg);
  font-weight: var(--weight-bold);
  color: var(--color-primary-deep);
}
.promo-banner .sub {
  font-size: var(--font-sm);
  color: var(--color-primary-dark);
}
.promo-badge {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
  flex-shrink: 0;
}
