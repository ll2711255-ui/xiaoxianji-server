@import './styles/tokens.wxss';
@import './styles/components.wxss';

/* ========== 全局设计系统 ========== */
/* 暖橙主调 · 卡片圆角 · 轻量阴影（视觉 token 见 styles/tokens.wxss） */

/* ---------- 保留：页面 wxss 仍在 var() 引用的品牌邻近色变量 ---------- */
/* 说明：这些变量被商家端头部/按钮/订单状态色等 20+ 页面引用，暂原样保留，
   后续步骤可逐个重映射到新橙色 token；此处删除会导致这些页面变量未定义而破样 */
page {
  --color-brand-main-red: #D4420A;
  --color-brand-chili-red: #FF5722;
  --color-brand-dark-red: #A83108;
  --color-brand-tangerine: #FF6B35;
  --color-brand-amber: #F5A623;
  --color-brand-gold: #FF9500;
  --color-brand-yolk: #FFCC00;
  --color-brand-cream: #FFF8E1;
  --color-brand-cream-bg: #FFFEF7;
  --color-brand-gold-bg: #FFF8E1;
  --color-brand-orange-bg: #FFF0E6;
  --color-brand-red-bg: #FFEBEE;
  --color-brand-soy-red-shadow: rgba(212, 66, 10, 0.35);
  --color-bg-warm-white: #FFFEF9;
}

/* ---------- page 基础（第一步：改为 token 驱动） ---------- */
page {
  background-color: var(--color-bg-page);
  color: var(--color-text-1);
  font-size: var(--font-base);
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ========== 通用容器 ========== */
.container {
  padding: 20rpx 24rpx;
}

/* ========== 卡片 ========== */
/* 卡片通用 */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.card-full {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
}

/* ========== 按钮 ========== */
/* .btn-primary 基础样式由 styles/components.wxss 提供（删旧用新）；此处仅保留交互态 */
.btn-primary:active {
  background: var(--color-primary-dark);
}

.btn-primary[disabled] {
  background: var(--color-bg-input);
  color: var(--color-text-3);
}

.btn-outline {
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 40rpx;
  font-size: var(--font-base);
  padding: 16rpx 32rpx;
  text-align: center;
}

.btn-outline:active {
  background: var(--color-primary-pale);
}

/* ========== 价格 ========== */
/* 价格统一用主色（橙），如需独立价格色可在后续步骤单列 token */
.price {
  color: var(--color-primary);
  font-weight: 700;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

/* ========== 标签 ========== */
/* .tag 基础样式由 styles/components.wxss 提供（删旧用新）；此处保留项目已用的颜色 modifier */
.tag-green {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.tag-orange {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.tag-red {
  background-color: var(--color-danger-bg);
  color: var(--color-danger);
}

.tag-gray {
  background-color: var(--color-bg-input);
  color: var(--color-text-2);
}

/* ========== 空状态 ========== */
/* .empty-state 基础样式由 styles/components.wxss 提供（删旧用新）；此处保留子元素样式 */
.empty-state .empty-icon {
  font-size: 104rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 32rpx;
}

.empty-state .empty-hint {
  font-size: 28rpx;
  margin-top: 12rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 24rpx;
  color: var(--color-text-3);
  font-size: 28rpx;
}

/* ========== 分割线 ========== */
/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 0 var(--space-md);
}

/* ========== 规格选择（全局复用） ========== */
.spec-group {
  margin-bottom: 32rpx;
}

.spec-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-1);
  margin-bottom: 16rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-option {
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  background-color: var(--color-bg-input);
  color: var(--color-text-1);
  border: 1px solid var(--color-border);
}

.spec-option.selected {
  background-color: var(--color-primary-pale);
  color: var(--color-primary);
  border-color: var(--color-primary);
}

/* ========== 底部安全区 ========== */
/* 安全区底部占位 */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}

/* ========== 手机号授权浮层（全局复用） ========== */
.phone-auth-overlay {
  position: fixed;
  z-index: 200;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-auth-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.phone-auth-card {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.phone-auth-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-1);
  margin-bottom: 12rpx;
}

.phone-auth-desc {
  font-size: 30rpx;
  color: var(--color-text-2);
  margin-bottom: 36rpx;
  line-height: 1.5;
}

.phone-auth-btn {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.phone-auth-btn::after {
  border: none;
}

.phone-auth-btn:active {
  opacity: 0.9;
}

.phone-auth-cancel {
  margin-top: 24rpx;
  padding: 16rpx 32rpx;
}

.phone-auth-cancel text {
  font-size: 30rpx;
  color: var(--color-text-3);
}
