/* ========== 全局设计系统 ========== */
/* 叮咚买菜风格：绿色主调、清新、圆角卡片 */

page {
  --color-primary: #1DB96A;
  --color-primary-light: #f0faf5;
  --color-price: #FF4B26;
  --color-danger: #FF3B30;
  --color-warning: #FF9500;
  --color-text: #1A1A1A;
  --color-text-secondary: #999;
  --color-text-hint: #C7C7CC;
  --color-bg: #F5F5F5;
  --color-card: #FFFFFF;
  --color-border: #EEEEEE;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-round: 40rpx;
  --shadow-card: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);

  /* ========== 2.0 品牌邻近色体系 ========== */
  /* 主红 → 辣椒红 → 深红（核心渐变轴） */
  --color-brand-main-red: #D4420A;
  --color-brand-chili-red: #FF5722;
  --color-brand-dark-red: #A83108;
  /* 蜜橘橙 → 琥珀 → 金黄 → 蛋黄（暖色渐变轴） */
  --color-brand-tangerine: #FF6B35;
  --color-brand-amber: #F5A623;
  --color-brand-gold: #FF9500;
  --color-brand-yolk: #FFCC00;
  /* 奶黄 / 米底 */
  --color-brand-cream: #FFF8E1;
  --color-brand-cream-bg: #FFFEF7;
  /* 品牌浅底变体 */
  --color-brand-gold-bg: #FFF8E1;
  --color-brand-orange-bg: #FFF0E6;
  --color-brand-red-bg: #FFEBEE;
  /* 酱红投影（按钮/卡片用） */
  --color-brand-soy-red-shadow: rgba(212, 66, 10, 0.35);
  /* 暖白页背景 */
  --color-bg-warm-white: #FFFEF9;
  /* 语义色补充 */
  --color-success: #34C759;
  --color-success-bg: #E8F8F0;

  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  font-size: 32rpx;
  color: #1A1A1A;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ========== 通用容器 ========== */
.container {
  padding: 20rpx 24rpx;
}

/* ========== 卡片 ========== */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-full {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* ========== 按钮 ========== */
.btn-primary {
  background: #1DB96A;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 16rpx 32rpx;
  text-align: center;
  border: none;
}

.btn-primary:active {
  background: #18a05b;
}

.btn-primary[disabled] {
  background: #E0E0E0;
  color: #999;
}

.btn-outline {
  background: #fff;
  color: #1DB96A;
  border: 2rpx solid #1DB96A;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 16rpx 32rpx;
  text-align: center;
}

.btn-outline:active {
  background: #f0faf5;
}

/* ========== 价格 ========== */
.price {
  color: #FF4B26;
  font-weight: 700;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF4B26;
}

.price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF4B26;
}

/* ========== 标签 ========== */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.tag-green {
  background-color: #E8F8F0;
  color: #1DB96A;
}

.tag-orange {
  background-color: #FFF5F0;
  color: #FF9500;
}

.tag-red {
  background-color: #FFEBEE;
  color: #FF3B30;
}

.tag-gray {
  background-color: #F5F5F5;
  color: #999;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  color: #C7C7CC;
}

.empty-state .empty-icon {
  font-size: 104rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state text {
  font-size: 32rpx;
}

.empty-state .empty-hint {
  font-size: 28rpx;
  margin-top: 12rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 24rpx;
  color: #C7C7CC;
  font-size: 28rpx;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background-color: #EEEEEE;
  margin: 20rpx 0;
}

/* ========== 规格选择（全局复用） ========== */
.spec-group {
  margin-bottom: 32rpx;
}

.spec-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.spec-option {
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  background-color: #F5F5F5;
  color: #1A1A1A;
  border: 1px solid #ddd;
}

.spec-option.selected {
  background-color: #f0faf5;
  color: #1DB96A;
  border-color: #1DB96A;
}

/* ========== 底部安全区 ========== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 手机号授权浮层（全局复用） ========== */
.phone-auth-overlay {
  position: fixed;
  z-index: 200;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-auth-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.phone-auth-card {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.phone-auth-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.phone-auth-desc {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 36rpx;
  line-height: 1.5;
}

.phone-auth-btn {
  width: 100%;
  height: 96rpx;
  background: #1DB96A;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.phone-auth-btn::after {
  border: none;
}

.phone-auth-btn:active {
  opacity: 0.9;
}

.phone-auth-cancel {
  margin-top: 24rpx;
  padding: 16rpx 32rpx;
}

.phone-auth-cancel text {
  font-size: 30rpx;
  color: #C7C7CC;
}
