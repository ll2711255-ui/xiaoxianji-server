# ========== 运行环境 ==========
NODE_ENV=production
PORT=3000

# ========== MySQL ==========
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=xiaoxianji
DB_PASSWORD=your_db_password
DB_NAME=xiaoxianji

# ========== Redis ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ========== JWT ==========
JWT_ACCESS_SECRET=your_access_secret_64_chars
JWT_REFRESH_SECRET=your_refresh_secret_64_chars
JWT_ACCESS_EXPIRES=7200
JWT_REFRESH_EXPIRES=2592000

# ========== 微信小程序 ==========
WX_APPID=your_miniapp_appid
WX_APPSECRET=your_miniapp_secret

# ========== 微信支付 V3 ==========
WXPAY_MCHID=your_mchid
WXPAY_SERIAL_NO=your_cert_serial_no
WXPAY_APIv3_KEY=your_api_v3_key
WXPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----

# ========== 回调地址 ==========
PAY_NOTIFY_URL=https://www.xuaioxianji.top/api/pay-callback
REFUND_NOTIFY_URL=https://www.xuaioxianji.top/api/pay-callback/refund

# ========== 其他 ==========
PASSWORD_SALT=xiaoxianji_salt
STORE_LAT=23.1291
STORE_LNG=113.2644
DELIVERY_RADIUS=5
