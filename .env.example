# ============================================================
# 小鲜鸡服务端环境变量模板
# 复制此文件为 .env 并填入真实值
# ============================================================

# ---- 运行环境 ----
NODE_ENV=production
PORT=3000

# ---- MySQL 数据库 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=xiaoxianji
DB_PASSWORD=your_db_password
DB_NAME=xiaoxianji

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT 密钥（至少32位随机字符串，生产环境必须修改！） ----
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars
# JWT_ACCESS_EXPIRES=604800    # 顾客端 7d，商家端 auth.routes.js 中硬编码 8h 覆盖
# JWT_REFRESH_EXPIRES=2592000  # 30d

# ---- 微信小程序 ----
WX_APPID=wx_your_appid
WX_APPSECRET=your_app_secret

# ---- 支付宝小程序（预留） ----
# ALIPAY_APPID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=

# ---- 抖音小程序（预留） ----
# TOUTIAO_APPID=
# TOUTIAO_APPSECRET=

# ---- 微信支付 V3 ----
WXPAY_MCHID=your_mchid
WXPAY_SERIAL_NO=your_cert_serial_no
WXPAY_APIv3_KEY=your_api_v3_key
# WXPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ---- 回调地址 ----
PAY_NOTIFY_URL=https://www.xuaioxianji.top/api/pay-callback
REFUND_NOTIFY_URL=https://www.xuaioxianji.top/api/pay-callback/refund
# ALIPAY_NOTIFY_URL=https://www.xuaioxianji.top/api/pay-callback/alipay
# TOUTIAO_NOTIFY_URL=https://www.xuaioxianji.top/api/pay-callback/tt

# ---- 店铺配置 ----
# STORE_LAT=23.1291
# STORE_LNG=113.2644
# DELIVERY_RADIUS=5

# ---- 业务参数 ----
# PAY_TIMEOUT_MINUTE=15
# BCRYPT_ROUNDS=10
